<%- include('../partials/header', { title: 'Socials Studio', user }) %>

<div class="page-header">
  <p class="muted" style="margin:0 0 4px;"><a class="row-link" href="/marketing">&larr; Marketing</a></p>
  <h1>Socials Studio</h1>
  <p class="muted">Four steps: sources → generate with Claude → push to website → push to Buffer. Nothing is stored in the Portal.</p>
</div>

<% if (!aiReady) { %><div class="alert alert-error">Claude isn't configured — add the API key in Settings → Integrations before generating.</div><% } %>
<% if (!websiteReady) { %><div class="alert alert-error">Website publishing isn't set up on the server yet — one-off: <code>mkdir -p /var/www/lumenmsp/news/live</code> (as lits-admin; the web root is already ours, no sudo). Site deploys preserve this folder automatically.</div><% } %>
<% if (!bufferReady) { %><div class="alert alert-error">Buffer isn't configured — add the API key in Settings → Integrations to push socials.</div><% } %>

<!-- Step 1 — sources -->
<div class="card">
  <div class="card-header"><h2>1 · Sources</h2></div>
  <div class="form-group" style="margin-bottom:12px;">
    <label>URLs (one per line — I'll read them for source material, up to 4)</label>
    <textarea id="stUrls" class="input" rows="3" style="width:100%;font-family:monospace;font-size:13.5px;" placeholder="https://www.ncsc.gov.uk/…&#10;https://…"></textarea>
  </div>
  <div class="form-group" style="margin-bottom:12px;">
    <label>Content (notes, key points, anything to include)</label>
    <textarea id="stContent" class="input" rows="5" style="width:100%;" placeholder="What's the story? Paste rough notes, bullet points, an email — anything."></textarea>
  </div>
  <div class="form-group">
    <label>Lumen's take (our angle — this shapes the article)</label>
    <textarea id="stTake" class="input" rows="3" style="width:100%;" placeholder="e.g. Most small firms think this doesn't apply to them — it does, and the fix is cheap."></textarea>
  </div>
</div>

<!-- Step 2 — generate -->
<div class="card">
  <div class="card-header"><h2>2 · Generate</h2></div>
  <p class="muted" style="margin:0 0 12px;">Claude writes one meaty article for <strong>end users</strong> (plain English, no tech-speak) plus LinkedIn and Facebook copy. Everything below stays editable.</p>
  <button class="btn btn-primary" id="genBtn" onclick="stGenerate()" <%= aiReady ? '' : 'disabled' %>>✨ Generate with Claude</button>
  <span id="genStatus" class="muted" style="margin-left:10px;"></span>

  <div id="genOut" style="display:none;margin-top:18px;">
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;">
      <div class="form-group" style="flex:2;min-width:280px;"><label>Title</label><input id="outTitle" class="input" style="width:100%;"></div>
      <div class="form-group" style="flex:1;min-width:200px;"><label>Slug (page address)</label><input id="outSlug" class="input" style="width:100%;font-family:monospace;font-size:13.5px;"></div>
    </div>
    <div class="form-group" style="margin-bottom:12px;"><label>Excerpt (preview line)</label><input id="outExcerpt" class="input" style="width:100%;"></div>
    <div class="form-group" style="margin-bottom:12px;"><label>Website article (HTML)</label><textarea id="outArticle" class="input" rows="16" style="width:100%;font-size:14.5px;"></textarea></div>
    <div style="display:flex;gap:12px;flex-wrap:wrap;">
      <div class="form-group" style="flex:1;min-width:300px;"><label>LinkedIn</label><textarea id="outLinkedin" class="input" rows="8" style="width:100%;"></textarea></div>
      <div class="form-group" style="flex:1;min-width:300px;"><label>Facebook</label><textarea id="outFacebook" class="input" rows="8" style="width:100%;"></textarea></div>
    </div>
    <div class="form-group" style="margin-top:14px;">
      <label>Hero photo (goes on the article and the social posts)</label>
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:10px;">
        <input id="imgQuery" class="input" placeholder="search free photos…" style="min-width:220px;">
        <button type="button" class="btn" onclick="imgSearch()">🔍 Search photos</button>
        <input id="imgUrl" class="input" placeholder="…or paste an image URL" style="min-width:260px;font-family:monospace;font-size:13px;" oninput="imgPick(this.value, null)">
      </div>
      <div id="imgGrid" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
      <div id="imgSel" class="muted" style="margin-top:6px;font-size:14px;">No photo selected — everything goes out text-only.</div>
    </div>
  </div>
</div>

<!-- Step 3 — website -->
<div class="card">
  <div class="card-header"><h2>3 · Push to website</h2></div>
  <p class="muted" style="margin:0 0 12px;">Publishes the article live at <strong>lumenmsp.co.uk/news/&lt;slug&gt;/</strong> instantly — no site rebuild.</p>
  <button class="btn" id="prevBtn" onclick="stPreview()" disabled>👁 Preview</button>
  <button class="btn btn-primary" id="webBtn" onclick="stPublish()" disabled>🌐 Push to website</button>
  <span id="webStatus" style="margin-left:10px;"></span>
</div>

<!-- Step 4 — Buffer -->
<div class="card">
  <div class="card-header"><h2>4 · Push to Buffer</h2></div>
  <p class="muted" style="margin:0 0 12px;">Sends the LinkedIn + Facebook copy (with the article link attached once it's published).</p>
  <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap;margin-bottom:12px;">
    <label style="display:flex;align-items:center;gap:6px;font-weight:600;"><input type="radio" name="bufMode" value="now" checked> Post now</label>
    <label style="display:flex;align-items:center;gap:6px;font-weight:600;"><input type="radio" name="bufMode" value="schedule"> Schedule for</label>
    <input type="datetime-local" id="bufWhen" class="input" style="width:auto;">
  </div>
  <button class="btn btn-primary" id="bufBtn" onclick="stBuffer()" disabled>📣 Push to Buffer</button>
  <span id="bufStatus" style="margin-left:10px;"></span>
</div>

<script>
function csrf(){ var m=document.querySelector('meta[name="csrf-token"]'); return m?m.getAttribute('content'):''; }
function jpost(url, body){ return fetch(url, { method:'POST', headers:{'Content-Type':'application/json','x-csrf-token':csrf()}, body: JSON.stringify(body) }).then(function(r){ return r.json(); }); }
var publishedUrl = '';
var selectedImage = '';

function imgSearch(){
  var q = document.getElementById('imgQuery').value.trim(); if(!q) return;
  var grid = document.getElementById('imgGrid');
  grid.innerHTML = '<span class="muted">Searching…</span>';
  fetch('/marketing/socials/image-search?q=' + encodeURIComponent(q)).then(function(r){ return r.json(); }).then(function(d){
    if(!d.ok || !d.images || !d.images.length){ grid.innerHTML = '<span class="muted">' + (d.error || 'No photos found — try different words, or paste a URL.') + '</span>'; return; }
    grid.innerHTML = '';
    d.images.forEach(function(im){
      var img = document.createElement('img');
      img.src = im.thumb; img.title = im.alt + ' — ' + im.credit;
      img.style.cssText = 'width:130px;height:88px;object-fit:cover;border-radius:8px;cursor:pointer;border:3px solid transparent;';
      img.onclick = function(){ imgPick(im.url, img); };
      grid.appendChild(img);
    });
  }).catch(function(){ grid.innerHTML = '<span class="muted">Search failed.</span>'; });
}
function imgPick(url, el){
  selectedImage = (url || '').trim();
  document.querySelectorAll('#imgGrid img').forEach(function(i){ i.style.borderColor = 'transparent'; });
  if (el) el.style.borderColor = '#0ea5b7';
  document.getElementById('imgSel').innerHTML = selectedImage
    ? '✔ Photo selected — it will appear on the article and both social posts.'
    : 'No photo selected — everything goes out text-only.';
  document.getElementById('imgSel').style.color = selectedImage ? '#166534' : '';
}

function stPreview(){
  // POST an invisible form to the preview endpoint in a new tab — the exact page publish would produce.
  var f = document.createElement('form');
  f.method = 'POST'; f.action = '/marketing/socials/preview-website'; f.target = '_blank';
  [['_csrf', csrf()], ['title', document.getElementById('outTitle').value], ['slug', document.getElementById('outSlug').value],
   ['excerpt', document.getElementById('outExcerpt').value], ['articleHtml', document.getElementById('outArticle').value],
   ['imageUrl', selectedImage]].forEach(function(kv){
    var i = document.createElement('input'); i.type = 'hidden'; i.name = kv[0]; i.value = kv[1]; f.appendChild(i);
  });
  document.body.appendChild(f); f.submit(); f.remove();
}

function stGenerate(){
  var b=document.getElementById('genBtn'), s=document.getElementById('genStatus');
  b.disabled=true; b.textContent='✨ Writing…'; s.textContent='Reading sources and drafting — 20–40 seconds.'; s.style.color='';
  jpost('/marketing/socials/generate', {
    urls: document.getElementById('stUrls').value,
    content: document.getElementById('stContent').value,
    take: document.getElementById('stTake').value
  }).then(function(d){
    b.disabled=false; b.textContent='✨ Generate with Claude';
    if(!d.ok){ s.textContent=d.error||'Failed'; s.style.color='#b91c1c'; return; }
    document.getElementById('outTitle').value=d.title; document.getElementById('outSlug').value=d.slug;
    document.getElementById('outExcerpt').value=d.excerpt; document.getElementById('outArticle').value=d.articleHtml;
    document.getElementById('outLinkedin').value=d.linkedin; document.getElementById('outFacebook').value=d.facebook;
    document.getElementById('genOut').style.display='block';
    document.getElementById('webBtn').disabled=false; document.getElementById('bufBtn').disabled=false;
    document.getElementById('prevBtn').disabled=false;
    if (d.imageQuery) { document.getElementById('imgQuery').value = d.imageQuery; imgSearch(); }
    s.textContent='Done — read ' + d.sourcesRead + ' of ' + d.sourcesGiven + ' URL(s). Edit anything below, then push.'; s.style.color='#166534';
  }).catch(function(){ b.disabled=false; b.textContent='✨ Generate with Claude'; s.textContent='Request failed.'; s.style.color='#b91c1c'; });
}

function stPublish(){
  var b=document.getElementById('webBtn'), s=document.getElementById('webStatus');
  b.disabled=true; b.textContent='🌐 Publishing…'; s.textContent='';
  jpost('/marketing/socials/publish-website', {
    title: document.getElementById('outTitle').value, slug: document.getElementById('outSlug').value,
    excerpt: document.getElementById('outExcerpt').value, articleHtml: document.getElementById('outArticle').value,
    imageUrl: selectedImage
  }).then(function(d){
    b.disabled=false; b.textContent='🌐 Push to website';
    if(!d.ok){ s.textContent=d.error||'Failed'; s.style.color='#b91c1c'; return; }
    publishedUrl=d.url;
    s.innerHTML='✔ Live: <a href="'+d.url+'" target="_blank" rel="noopener">'+d.url+'</a>'; s.style.color='#166534';
  }).catch(function(){ b.disabled=false; b.textContent='🌐 Push to website'; s.textContent='Request failed.'; s.style.color='#b91c1c'; });
}

function stBuffer(){
  var b=document.getElementById('bufBtn'), s=document.getElementById('bufStatus');
  var mode=document.querySelector('input[name="bufMode"]:checked').value;
  var when=document.getElementById('bufWhen').value;
  var dueAt = (mode==='schedule' && when) ? new Date(when).toISOString() : undefined;
  if(mode==='schedule' && !dueAt){ s.textContent='Pick a date and time first.'; s.style.color='#b91c1c'; return; }
  if(!publishedUrl && !confirm('The article hasn\'t been pushed to the website yet, so the posts will go out without a link. Continue?')) return;
  b.disabled=true; b.textContent='📣 Pushing…'; s.textContent='';
  jpost('/marketing/socials/push-buffer', {
    linkedin: document.getElementById('outLinkedin').value, facebook: document.getElementById('outFacebook').value,
    mode: mode, dueAt: dueAt, link: publishedUrl, imageUrl: selectedImage
  }).then(function(d){
    b.disabled=false; b.textContent='📣 Push to Buffer';
    if(!d.ok){ s.textContent=d.error||'Failed'; s.style.color='#b91c1c'; return; }
    s.textContent = Object.keys(d.results).map(function(k){ return k+': '+d.results[k]; }).join(' · ');
    s.style.color = JSON.stringify(d.results).indexOf('FAILED')>=0 ? '#b45309' : '#166534';
  }).catch(function(){ b.disabled=false; b.textContent='📣 Push to Buffer'; s.textContent='Request failed.'; s.style.color='#b91c1c'; });
}
</script>

<%- include('../partials/footer') %>
