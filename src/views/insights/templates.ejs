<%
  function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]; }); }
  var rowsHtml = (templates || []).map(function(t){
    var mods = Array.isArray(t.modules) ? t.modules : [];
    var del = t.is_system ? '' : '<form method="post" action="/insights/templates/' + t.id + '/delete" style="display:inline;margin-left:6px;" onsubmit="return confirm(\'Delete this template?\');"><button class="btn-secondary" type="submit" style="font-size:12px;padding:4px 10px;">Delete</button></form>';
    return '<tr style="border-bottom:1px solid #e5e7eb;">'
      + '<td style="padding:10px 12px;"><strong>' + esc(t.name) + '</strong>' + (t.is_system ? ' <span style="font-size:10px;background:#eef2ff;color:#3730a3;padding:2px 7px;border-radius:20px;">system</span>' : '') + '</td>'
      + '<td style="padding:10px 12px;color:#6b7280;font-size:12px;">' + (mods.length ? esc(mods.join(', ')) : '—') + '</td>'
      + '<td style="padding:10px 12px;text-align:right;white-space:nowrap;"><a class="btn-secondary" href="/insights/templates/' + t.id + '/edit" style="font-size:12px;padding:4px 10px;">Edit</a>' + del + '</td>'
      + '</tr>';
  }).join('');
  if (!(templates || []).length) rowsHtml = '<tr><td colspan="3" style="padding:20px;color:#6b7280;">No templates yet — create one.</td></tr>';
%>
<%- include('_layout', { title: 'Reports', user, csrfToken: (typeof csrfToken !== 'undefined' ? csrfToken : ''), body: `
  <div class="page-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
    <div><h1>Report Pool</h1><p style="color:#6b7280;margin:4px 0 0;">Reusable report templates — a name + a set of modules, available to every customer. The site's logic drives the numbers.</p></div>
    <a class="btn-primary" href="/insights/templates/new" style="padding:8px 16px;">+ New template</a>
  </div>
  ${msg ? '<div style="background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;padding:10px 14px;border-radius:8px;margin-bottom:14px;">' + esc(msg) + '</div>' : ''}
  ${err ? '<div style="background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;padding:10px 14px;border-radius:8px;margin-bottom:14px;">' + esc(err) + '</div>' : ''}
  <div class="card" style="padding:0;">
    <table style="width:100%;border-collapse:collapse;font-size:14px;">
      <thead><tr style="border-bottom:2px solid #e5e7eb;">
        <th style="text-align:left;padding:10px 12px;font-size:11px;text-transform:uppercase;letter-spacing:.4px;color:#6b7280;">Template</th>
        <th style="text-align:left;padding:10px 12px;font-size:11px;text-transform:uppercase;letter-spacing:.4px;color:#6b7280;">Modules</th>
        <th></th></tr></thead>
      <tbody>${rowsHtml}</tbody>
    </table>
  </div>
` }) %>
