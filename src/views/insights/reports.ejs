<%
// Locals (reports, configs, customers, flash, error) are always passed by the
// route — reference them directly; don't redeclare (TDZ shadowing of with(locals)).
const isAdmin = true; // portal staff

const fmtDate = d => d ? new Date(d).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) : '—';
const fmtDt   = d => d ? new Date(d).toLocaleString('en-GB', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—';

const reportRows = reports.map(r => {
  const start = fmtDate(r.report_start);
  const endIncl = r.report_end ? new Date(new Date(r.report_end).getTime() - 86400000) : null;
  const end   = fmtDate(endIncl);
  const gen   = fmtDt(r.generated_at);
  const badge = r.status === 'sent' ? 'badge-sent' : 'badge-primary';
  const regenDateField = r.report_type === 'weekly_call_stats'
    ? `<input type="hidden" name="date_from" value="${new Date(r.report_start).toISOString().slice(0,10)}">`
    : `<input type="hidden" name="report_date" value="${new Date(r.report_start).toISOString().slice(0,10)}">`;
  return `
    <tr>
      <td><strong>${r.config_label || r.report_type}</strong></td>
      <td style="font-size:13px;color:var(--muted);">${r.customer_name}</td>
      <td style="font-size:13px;color:var(--muted);">${r.site_label}</td>
      <td style="font-size:13px;">${start} – ${end}</td>
      <td style="font-size:12px;color:var(--muted);">${gen}</td>
      <td><span class="badge ${badge}">${r.status}</span></td>
      <td style="display:flex;gap:6px;align-items:center;">
        <a href="/insights/reports/${r.id}" target="_blank" class="btn-secondary" style="font-size:12px;padding:4px 10px;">Open</a>
        <form method="POST" action="/insights/reports/${r.id}/email" style="display:inline;">
          <button type="submit" class="btn-secondary" style="font-size:12px;padding:4px 10px;" title="Email this report">Email</button>
        </form>
        <form method="POST" action="/insights/reports/generate" style="display:inline;">
          <input type="hidden" name="config_id" value="${r.config_id}">
          ${regenDateField}
          <button type="submit" class="btn-secondary" style="font-size:12px;padding:4px 10px;" title="Re-generate this report">Regenerate</button>
        </form>
      </td>
    </tr>`;
}).join('');

const uniqueCustomers = [...new Map(reports.map(r => [r.customer_name, r.customer_name])).values()];
const uniqueConfigs   = [...new Map(reports.map(r => [r.config_label, {label: r.config_label, id: r.config_id}])).values()];
const filterCustomer = '';
const filterConfig = '';
%>
<%- include('_layout', { title: 'Reports', user, csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '', body: `

${flash ? `<div class="alert alert-success">${flash}</div>` : ''}
${error ? `<div class="alert alert-error">${error}</div>` : ''}

<div class="card" style="border:2px solid var(--accent);background:linear-gradient(135deg,#f0fdf9 0%,#e0f2fe 100%);">
  <div class="card-header">
    <h2>Generate Report</h2>
  </div>
  <form method="POST" action="/insights/reports/generate" id="gen-form" style="display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap;">

    <div class="form-group" style="margin:0;">
      <label>Customer</label>
      <select id="gen-customer" class="input" onchange="filterConfigs(this.value)" style="min-width:200px;">
        <option value="">— Select customer —</option>
        ${customers.map(c => `<option value="${c.id}">${c.name}</option>`).join('')}
      </select>
    </div>

    <div class="form-group" style="margin:0;">
      <label>Report</label>
      <select id="gen-config" name="config_id" class="input" onchange="onConfigChange(this)" style="min-width:220px;" required>
        <option value="">— Select report —</option>
        ${configs.map(c => `<option value="${c.id}" data-type="${c.report_type}" data-customer="${c.customer_id}">${c.customer_name} — ${c.config_label}</option>`).join('')}
      </select>
    </div>

    <div id="week-picker" style="display:none;align-items:flex-end;">
      <div class="form-group" style="margin:0;">
        <label>Week</label>
        <select id="gen-week" name="week" class="input" style="min-width:210px;padding:10px 12px;">
          ${(() => {
            const opts = [];
            const now = new Date(); now.setUTCHours(0,0,0,0);
            const d = new Date(now);
            d.setUTCDate(d.getUTCDate() + (d.getUTCDay() === 0 ? -6 : 1 - d.getUTCDay()));
            const fmt = (x) => x.toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' });
            for (let i = 0; i < 26; i++) {
              const mon = new Date(d); mon.setUTCDate(mon.getUTCDate() - i*7);
              const sun = new Date(mon); sun.setUTCDate(sun.getUTCDate() + 6);
              opts.push('<option value="' + mon.toISOString().slice(0,10) + '"' + (i===1?' selected':'') + '>' + fmt(mon) + ' – ' + fmt(sun) + '</option>');
            }
            return opts.join('');
          })()}
        </select>
      </div>
    </div>

    <div id="date-range-picker" style="display:none;gap:8px;align-items:flex-end;">
      <div class="form-group" style="margin:0;display:none;" id="preset-wrap">
        <label>Range</label>
        <select id="gen-preset" class="input" onchange="applyPreset(this.value)" style="min-width:150px;padding:10px 12px;">
          <option value="">Custom…</option>
          <option value="30" selected>Last 30 days</option>
          <option value="90">Last 90 days</option>
          <option value="month">This month</option>
          <option value="lastmonth">Last month</option>
          <option value="quarter">This quarter</option>
          <option value="year">This year</option>
        </select>
      </div>
      <div class="form-group" style="margin:0;">
        <label id="date-from-label">Date</label>
        <input type="date" id="gen-date-from" name="date_from" class="input" style="padding:10px 12px;">
      </div>
      <div class="form-group" style="margin:0;" id="date-to-wrap">
        <label>To</label>
        <input type="date" id="gen-date-to" name="date_to" class="input" style="padding:10px 12px;">
      </div>
    </div>

    <button type="submit" id="gen-btn" class="btn-primary" disabled style="padding:10px 20px;font-size:14px;">Generate</button>
  </form>
</div>

<div class="card">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <h2>Generated Reports</h2>
    <form method="GET" action="/insights/reports" style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
      <div class="form-group" style="margin:0;">
        <label style="font-size:11px;">Customer</label>
        <select name="fc" class="input" style="font-size:12px;padding:6px 8px;" onchange="this.form.submit()">
          <option value="">All customers</option>
          ${uniqueCustomers.map(n => `<option value="${n}" ${filterCustomer===n?'selected':''}>${n}</option>`).join('')}
        </select>
      </div>
      <div class="form-group" style="margin:0;">
        <label style="font-size:11px;">Report</label>
        <select name="frc" class="input" style="font-size:12px;padding:6px 8px;" onchange="this.form.submit()">
          <option value="">All reports</option>
          ${uniqueConfigs.map(c => `<option value="${c.label}" ${filterConfig===c.label?'selected':''}>${c.label}</option>`).join('')}
        </select>
      </div>
    </form>
  </div>
  ${reports.length === 0
    ? '<div class="empty-state"><p class="muted">No reports generated yet. Use the form above.</p></div>'
    : `<div class="table-wrap"><table class="table">
        <thead><tr>
          <th>Report</th><th>Customer</th><th>Site</th><th>Period</th><th>Generated</th><th>Status</th><th></th>
        </tr></thead>
        <tbody>${reportRows}</tbody>
       </table></div>`}
</div>

<script>
(function() {
  const configSel = document.getElementById('gen-config');
  const genBtn    = document.getElementById('gen-btn');

  function filterConfigs(customerId) {
    const opts = configSel.options;
    for (let i = 1; i < opts.length; i++) {
      opts[i].style.display = (!customerId || opts[i].dataset.customer === customerId) ? '' : 'none';
    }
    configSel.value = '';
    document.getElementById('week-picker').style.display = 'none';
    document.getElementById('date-range-picker').style.display = 'none';
    genBtn.disabled = true;
  }
  window.filterConfigs = filterConfigs;

  function onConfigChange(sel) {
    const opt = sel.options[sel.selectedIndex];
    const rtype = opt && opt.dataset ? opt.dataset.type : '';
    const weekP  = document.getElementById('week-picker');
    const picker = document.getElementById('date-range-picker');
    const toWrap = document.getElementById('date-to-wrap');
    const fromLbl = document.getElementById('date-from-label');
    const presetWrap = document.getElementById('preset-wrap');
    if (rtype === 'weekly_call_stats') {
      weekP.style.display = 'flex';
      picker.style.display = 'none';
    } else if (rtype === 'site_performance') {
      weekP.style.display = 'none';
      picker.style.display = 'flex';
      fromLbl.textContent = 'From';
      toWrap.style.display = '';
      if (presetWrap) presetWrap.style.display = '';
    } else if (rtype) {
      weekP.style.display = 'none';
      picker.style.display = 'flex';
      fromLbl.textContent = 'Date';
      toWrap.style.display = 'none';
      if (presetWrap) presetWrap.style.display = 'none';
    } else {
      weekP.style.display = 'none';
      picker.style.display = 'none';
    }
    genBtn.disabled = !rtype;
    const today = new Date().toISOString().slice(0, 10);
    const toInput = document.getElementById('gen-date-to');
    if (toInput) toInput.value = today;
    if (rtype === 'site_performance') {
      const ps = document.getElementById('gen-preset'); if (ps) ps.value = '30';
      applyPreset('30'); // default to the last 30 days
    } else {
      const fromInput = document.getElementById('gen-date-from');
      if (fromInput) fromInput.value = today;
    }
  }
  window.onConfigChange = onConfigChange;

  // Date-range presets for Site Performance — set the from/to pickers (which stay editable for custom).
  function applyPreset(v) {
    const fromInput = document.getElementById('gen-date-from');
    const toInput = document.getElementById('gen-date-to');
    if (!fromInput || !toInput) return;
    if (v === '') return; // Custom — leave the pickers as the user set them
    const now = new Date(); now.setUTCHours(0, 0, 0, 0);
    let from = new Date(now), to = new Date(now);
    if (v === '30' || v === '90') { from = new Date(now); from.setUTCDate(from.getUTCDate() - (Number(v) - 1)); }
    else if (v === 'month')     { from = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 1)); }
    else if (v === 'lastmonth') { from = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth() - 1, 1)); to = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 0)); }
    else if (v === 'quarter')   { from = new Date(Date.UTC(now.getUTCFullYear(), Math.floor(now.getUTCMonth() / 3) * 3, 1)); }
    else if (v === 'year')      { from = new Date(Date.UTC(now.getUTCFullYear(), 0, 1)); }
    fromInput.value = from.toISOString().slice(0, 10);
    toInput.value = to.toISOString().slice(0, 10);
  }
  window.applyPreset = applyPreset;

  document.getElementById('gen-form').addEventListener('submit', function(e) {
    if (!configSel.value) { e.preventDefault(); return; }
    genBtn.textContent = 'Generating…';
    genBtn.disabled = true;
  });
})();
</script>
` }) %>
