<%
// `reports` is always passed by the route. flash/error are derived below.
const flashMsg = (typeof notice !== 'undefined' && notice) ? notice : null;
const errMsg   = (typeof qerr !== 'undefined' && qerr) ? qerr : null;

const fmtDate = d => d ? new Date(d).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) : '—';
const fmtDt   = d => d ? new Date(d).toLocaleString('en-GB', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—';
const isWeekly = cfg.report_type === 'weekly_call_stats';
const recips = Array.isArray(cfg.recipients) ? cfg.recipients : String(cfg.recipients||'').split(/[\n,;]+/).map(s => s.replace(/[{}"]/g,'').trim()).filter(s => s.indexOf('@') >= 0);
const backUrl = cfg.ins_customer_id ? `/insights/customer/${cfg.ins_customer_id}` : '/insights/customers';

const repRows = reports.map(r => `
  <tr>
    <td style="font-size:13px;white-space:nowrap;">${fmtDate(r.report_start)}${r.report_end ? ' – ' + fmtDate(new Date(new Date(r.report_end).getTime() - 86400000)) : ''}</td>
    <td><span class="badge ${r.status === 'sent' ? 'badge-sent' : r.status === 'generated' ? 'badge-primary' : 'badge-inactive'}">${r.status}</span></td>
    <td style="font-size:12px;color:var(--muted);white-space:nowrap;">${fmtDt(r.generated_at || r.created_at)}</td>
    <td style="display:flex;gap:6px;">
      <a href="/insights/reports/${r.id}" target="_blank" class="btn-secondary" style="font-size:12px;padding:4px 10px;">Open</a>
      <form method="POST" action="/insights/reports/${r.id}/email" style="display:inline;margin:0;" onsubmit="return confirm('Re-email this report to its configured recipients?');">
        <button type="submit" class="btn-secondary" style="font-size:12px;padding:4px 10px;">Email</button>
      </form>
    </td>
  </tr>`).join('');
%>
<%- include('_layout', { title: cfg.config_label, user, csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '', body: `
<div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
  <div>
    <h1>${cfg.config_label}</h1>
    <p class="muted"><a href="${backUrl}">${cfg.customer_name}</a> → <a href="/insights/site/${cfg.site_id}">${cfg.site_label}</a> → ${cfg.report_type}${cfg.is_active === false ? ' · <span class="badge badge-inactive">inactive</span>' : ''}</p>
  </div>
  <a href="/insights/report-config/${cfg.id}/edit" class="btn-primary">Edit settings</a>
</div>

${flashMsg ? `<div class="alert alert-success">${flashMsg}</div>` : ''}
${errMsg ? `<div class="alert alert-error">${errMsg}</div>` : ''}

<div class="card" style="background:linear-gradient(135deg,#0f172a,#1e293b);border:none;color:#fff;">
  <h2 style="margin:0 0 4px;color:#fff;">⚡ Generate report</h2>
  <p style="margin:0 0 14px;color:#cbd5e1;font-size:13px;">${isWeekly ? 'Pick any date in the target week — the report always runs Mon–Sun for that week.' : 'Pick the day to report on.'}</p>
  <form method="POST" action="/insights/report-config/${cfg.id}/generate" style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;margin:0;">
    <input type="hidden" name="report_type" value="${isWeekly ? 'weekly' : 'daily'}">
    <div>
      <label style="display:block;font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8;margin-bottom:4px;">${isWeekly ? 'Week of' : 'Date'}</label>
      <input class="input" type="date" name="report_date" required style="min-width:180px;">
    </div>
    <button class="btn-primary" type="submit" style="padding:9px 18px;">Generate &amp; email</button>
    <button class="btn-secondary" type="submit" name="no_email" value="true" style="padding:9px 18px;background:#334155;color:#fff;border-color:#475569;">Generate only</button>
  </form>
</div>

<div class="card">
  <div class="card-header"><h2>Details</h2></div>
  <table class="table" style="margin:0;"><tbody>
    <tr><th style="width:38%;">Type</th><td>${cfg.report_type}</td></tr>
    <tr><th>Site</th><td><a class="row-link" href="/insights/site/${cfg.site_id}">${cfg.site_label}</a></td></tr>
    <tr><th>Recipients</th><td>${recips.length ? recips.join(', ') : '<span class="muted">— none set —</span>'}</td></tr>
    <tr><th>Active</th><td>${cfg.is_active ? 'Yes' : 'No'}</td></tr>
  </tbody></table>
</div>

<div class="card">
  <div class="card-header"><h2>Generated Reports <span class="muted" style="font-weight:400;font-size:14px;">(${reports.length})</span></h2></div>
  ${!reports.length
    ? '<div class="empty-state"><p class="muted">No reports generated for this config yet.</p></div>'
    : `<div class="table-wrap"><table class="table">
        <thead><tr><th>Period</th><th>Status</th><th>Generated</th><th></th></tr></thead>
        <tbody>${repRows}</tbody>
       </table></div>`}
</div>
` }) %>
