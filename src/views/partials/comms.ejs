<style>
  .email-body { overflow-x:auto; }
  .email-body img { max-width:100%; height:auto; }
  .email-body table { max-width:100%; }
  .email-body a { word-break:break-word; }
</style>
<div class="card" id="comms">
  <% var commCollapsed = (typeof collapsed !== 'undefined' && collapsed); %>
  <details <%= commCollapsed ? '' : 'open' %>>
  <summary style="list-style:none;cursor:pointer;display:flex;align-items:center;gap:8px;margin-bottom:14px;">
    <h2 style="margin:0;display:inline;">Composer</h2>
    <span class="muted" style="font-size:13px;">(<%= comms ? comms.length : 0 %>)</span>
  </summary>

  <% if (!comms || comms.length === 0) { %>
    <p class="muted" style="margin:0 0 16px;">No messages yet.</p>
  <% } else { %>
    <div style="margin-bottom:16px;">
      <% comms.forEach(function(m){ var inbound = m.direction === 'inbound'; var atts = []; try { atts = m.attachments ? JSON.parse(m.attachments) : []; } catch (e) {} %>
        <div style="border:1px solid <%= inbound ? '#fde68a' : 'var(--line)' %>;background:<%= inbound ? '#fffbeb' : '#eff6ff' %>;border-radius:10px;padding:12px 14px;margin-bottom:10px;">
          <div style="display:flex;justify-content:space-between;gap:12px;font-size:12px;margin-bottom:6px;">
            <strong><%= inbound ? 'From ' + (m.from_name || m.from_email || 'customer') : 'Sent' + (m.sent_by_name ? ' by ' + m.sent_by_name : '') %><% if (m.to_email && !inbound) { %> &rarr; <%= m.to_email %><% } %></strong>
            <span class="muted"><%= new Date(m.created_at).toLocaleString('en-GB') %><% if (inbound && m.is_unread) { %> · <span class="badge badge-primary">new</span><% } %></span>
          </div>
          <% if (m.subject) { %><div style="font-weight:600;font-size:13px;margin-bottom:4px;"><%= m.subject %></div><% } %>
          <div class="email-body" style="font-size:14px;line-height:1.6;overflow-wrap:anywhere;"><%- m.body %></div>
          <% if (atts.length) { %>
            <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:8px;">
              <% atts.forEach(function(a){ %><a href="<%= a.url %>" target="_blank" class="badge" style="text-decoration:none;">&#128206; <%= a.name %></a><% }); %>
            </div>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>

  <form method="post" action="/comms" enctype="multipart/form-data" style="border-top:1px solid var(--line);padding-top:16px;"
        onsubmit="document.getElementById('commsBody<%= entityId %>').value = window.commsQuill<%= entityId %>.root.innerHTML;">
    <input type="hidden" name="entity_type" value="<%= entityType %>">
    <input type="hidden" name="entity_id" value="<%= entityId %>">
    <input type="hidden" name="body" id="commsBody<%= entityId %>">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
      <div class="form-group"><label>To</label>
        <input class="input" type="email" name="to_email" list="commsTo<%= entityId %>" value="<%= typeof toEmail !== 'undefined' && toEmail ? toEmail : '' %>" placeholder="Pick a contact or type an address">
        <% if (typeof toContacts !== 'undefined' && toContacts && toContacts.length) { %>
        <datalist id="commsTo<%= entityId %>"><% toContacts.forEach(function(c){ if (c.email) { %><option value="<%= c.email %>"><%= c.full_name %><%= c.job_title ? ' · ' + c.job_title : '' %></option><% } }); %></datalist>
        <% } %>
      </div>
      <div class="form-group"><label>Subject</label><input class="input" name="subject" value="<%= typeof commsSubject !== 'undefined' ? commsSubject : '' %>"></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
      <div class="form-group"><label>Cc <span class="muted" style="font-weight:400;">(comma-separated)</span></label><input class="input" name="cc" placeholder="name@example.com, …"></div>
      <div class="form-group"><label>Bcc <span class="muted" style="font-weight:400;">(comma-separated)</span></label><input class="input" name="bcc" placeholder="name@example.com, …"></div>
    </div>
    <div class="form-group" style="margin-bottom:12px;"><label>Message</label>
      <div id="commsEditor<%= entityId %>" style="height:170px;background:#fff;"></div>
    </div>
    <div class="form-group" style="margin-bottom:12px;"><label>Attachments <span class="muted">(up to 5, 10MB each)</span></label>
      <input class="input" type="file" name="attachments" multiple>
    </div>
    <button class="btn btn-primary" type="submit">Send email</button>
  </form>
  </details>
</div>

<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script src="/static/grammar.js"></script>
<script>
  window.commsQuill<%= entityId %> = new Quill('#commsEditor<%= entityId %>', {
    theme: 'snow',
    placeholder: 'Write a message…',
    modules: { toolbar: [
      [{ font: [] }, { size: [] }],
      ['bold', 'italic', 'underline', 'strike'],
      [{ color: [] }, { background: [] }],
      [{ list: 'ordered' }, { list: 'bullet' }],
      ['link'],
      ['clean'],
    ] },
  });
  if (window.LumenGrammar) LumenGrammar.attach(window.commsQuill<%= entityId %>, document.getElementById('commsEditor<%= entityId %>').parentNode);
</script>
