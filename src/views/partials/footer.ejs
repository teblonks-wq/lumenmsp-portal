</main>

<script>
  (function () {
    var path = window.location.pathname;
    document.querySelectorAll('.sidebar-nav .nav-item').forEach(function (a) {
      var href = a.getAttribute('href');
      var active = href === '/' ? path === '/' : path.indexOf(href) === 0;
      if (active) a.classList.add('active');
    });
    var btn = document.getElementById('sidebarToggle');
    if (btn) btn.addEventListener('click', function () {
      var collapsed = document.documentElement.classList.toggle('nav-collapsed');
      try { localStorage.setItem('portalNavCollapsed', collapsed ? '1' : '0'); } catch (e) {}
    });
  })();

  // ── Global click-to-sort for any <table class="sortable"> ──────────────────────
  // Click a header to sort by that column (toggles asc/desc). Uses a cell's data-sort
  // attribute when present (e.g. epoch for dates, seconds for durations), else the cell
  // text — auto-detecting numbers (strips £ , % etc). Empty-state rows stay put.
  (function () {
    function val(row, i) {
      var cell = row.children[i]; if (!cell) return '';
      var ds = cell.getAttribute('data-sort');
      return ds !== null ? ds : (cell.textContent || '').trim();
    }
    function asNum(s) { var n = parseFloat(String(s).replace(/[^0-9.\-]/g, '')); return isNaN(n) ? null : n; }
    document.querySelectorAll('table.sortable').forEach(function (table) {
      var head = table.tHead; if (!head || !head.rows.length) return;
      var ths = Array.prototype.slice.call(head.rows[head.rows.length - 1].cells);
      ths.forEach(function (th, idx) {
        if (th.getAttribute('data-nosort') !== null || !th.textContent.trim()) return;
        th.style.cursor = 'pointer'; th.style.userSelect = 'none';
        var arrow = document.createElement('span'); arrow.className = 'sort-arrow'; arrow.style.opacity = '.5'; arrow.style.fontSize = '10px';
        th.appendChild(document.createTextNode(' ')); th.appendChild(arrow);
        th.addEventListener('click', function () {
          var body = table.tBodies[0]; if (!body) return;
          var rows = Array.prototype.slice.call(body.rows).filter(function (r) { return !r.querySelector('.empty-state') && r.children.length > idx; });
          var dir = th.getAttribute('data-dir') === 'asc' ? -1 : 1;
          ths.forEach(function (o) { o.removeAttribute('data-dir'); var a = o.querySelector('.sort-arrow'); if (a) a.textContent = ''; });
          th.setAttribute('data-dir', dir === 1 ? 'asc' : 'desc'); arrow.textContent = dir === 1 ? ' ▲' : ' ▼'; arrow.style.opacity = '1';
          rows.sort(function (a, b) {
            var x = val(a, idx), y = val(b, idx), nx = asNum(x), ny = asNum(y);
            if (nx !== null && ny !== null) return (nx - ny) * dir;
            return String(x).localeCompare(String(y), undefined, { numeric: true, sensitivity: 'base' }) * dir;
          });
          rows.forEach(function (r) { body.appendChild(r); });
        });
      });
    });
  })();

  // ── CSRF: inject the per-session token into every form + same-origin fetch ──────
  (function () {
    var meta = document.querySelector('meta[name="csrf-token"]');
    var T = meta ? meta.getAttribute('content') : '';
    if (!T) return;
    function ensure(form) {
      if (!form || (form.method || 'get').toUpperCase() === 'GET') return;
      if (!form.querySelector('input[name="_csrf"]')) {
        var i = document.createElement('input'); i.type = 'hidden'; i.name = '_csrf'; i.value = T; form.appendChild(i);
      }
      // Native multipart submits are parsed after our middleware runs, so also pass the token
      // in the query string where it's always visible.
      if ((form.enctype || '').toLowerCase() === 'multipart/form-data') {
        try { var u = new URL(form.getAttribute('action') || location.href, location.href); u.searchParams.set('_csrf', T); form.setAttribute('action', u.pathname + u.search); } catch (e) {}
      }
    }
    document.querySelectorAll('form').forEach(ensure);
    document.addEventListener('submit', function (e) { ensure(e.target); }, true);
    // Native form.submit() (used by dynamically-built forms, e.g. bulk actions) doesn't fire the
    // submit event, so patch it to inject the token first.
    var nativeSubmit = HTMLFormElement.prototype.submit;
    HTMLFormElement.prototype.submit = function () { try { ensure(this); } catch (e) {} return nativeSubmit.apply(this, arguments); };
    // Patch fetch to add the header on same-origin state-changing requests.
    var of = window.fetch;
    window.fetch = function (input, init) {
      init = init || {};
      var method = (init.method || (input && typeof input !== 'string' && input.method) || 'GET').toUpperCase();
      var url = (typeof input === 'string') ? input : (input && input.url) || '';
      var sameOrigin = url.indexOf('http') !== 0 || url.indexOf(location.origin) === 0;
      if (['POST', 'PUT', 'PATCH', 'DELETE'].indexOf(method) >= 0 && sameOrigin) {
        var h = new Headers(init.headers || (input && typeof input !== 'string' && input.headers) || {});
        if (!h.has('x-csrf-token')) h.set('x-csrf-token', T);
        init.headers = h;
      }
      return of(input, init);
    };
  })();
</script>

<% if (typeof user !== 'undefined' && user) { %>
  <!-- WhatsApp softphone (staff): rings here when a customer calls the WhatsApp number -->
  <script src="/static/js/call-widget.js" defer></script>
  <!-- Lumen Chat: the AGENT end of the website chat bot — staff answer web chats from here -->
  <script src="/static/js/agent-chat.js" defer></script>
  <!-- N3twrx nav badge: live open-alert count, coloured by worst current severity -->
  <script>
  (function(){
    var b = document.getElementById('n3Badge'); if (!b) return;
    function colour(s){ return s==='critical'?'#ef4444':(s==='warning'?'#f59e0b':'#2563eb'); }
    function upd(){
      fetch('/n3twrx/alerts.json').then(function(r){return r.json();}).then(function(rows){
        if (!rows || !rows.length){ b.style.display='none'; return; }
        var sev = rows.some(function(a){return a.severity==='critical';}) ? 'critical'
                : rows.some(function(a){return a.severity==='warning';}) ? 'warning' : 'info';
        b.textContent = rows.length; b.style.background = colour(sev); b.style.display='inline-flex';
      }).catch(function(){});
    }
    upd(); setInterval(upd, 15000);
    window.__n3Refresh = upd;   // call-widget pings this on a real-time alert
  })();
  </script>
  <!-- Chat inbox: untagged WhatsApp/Teams message count on the Chat nav badge -->
  <script>
  (function(){
    var b = document.getElementById('navChatBadge'); if (!b) return;
    function upd(){
      fetch('/chat/msg/untagged-count').then(function(r){return r.json();}).then(function(j){
        var n = (j && j.n) || 0;
        if (n > 0){ b.textContent = n; b.style.background = '#ef4444'; b.style.display = 'inline-flex'; }
      }).catch(function(){});
    }
    upd(); setInterval(upd, 30000);
  })();
  </script>
  <!-- Support nav badge: tickets awaiting an engineer -->
  <script>
  (function(){
    var b = document.getElementById('navSupportBadge'); if (!b) return;
    function upd(){
      fetch('/tickets/nav/awaiting-count').then(function(r){return r.json();}).then(function(j){
        var n = (j && j.n) || 0;
        if (n > 0){ b.textContent = n; b.style.display = 'inline-flex'; } else { b.style.display = 'none'; }
      }).catch(function(){});
    }
    upd(); setInterval(upd, 30000);
  })();
  </script>
<% } %>

