<%- include('../partials/header', { title: quote && quote.id ? 'Edit quote' : 'New quote', user }) %>

<% var isEdit = quote && quote.id; %>
<% function v(f){ return quote && quote[f] != null ? quote[f] : ''; } %>
<% function dateVal(f){ if(!quote || !quote[f]) return ''; try { return new Date(quote[f]).toISOString().slice(0,10); } catch(e){ return quote[f]; } } %>

<div class="page-header">
  <p class="muted" style="margin:0 0 4px;"><a class="row-link" href="<%= isEdit ? '/quotes/' + quote.id : '/quotes' %>">← Back</a></p>
  <h1><%= isEdit ? 'Edit quote' : 'New quote' %></h1>
</div>

<% if (error) { %><div class="alert alert-error" style="max-width:900px;"><%= error %></div><% } %>

<form method="post" action="<%= isEdit ? '/quotes/' + quote.id : '/quotes' %>">
  <div class="card">
    <div class="card-header"><h2>Details</h2></div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">
      <div class="form-group" style="grid-column:1 / -1;"><label>Title *</label><input class="input" name="title" required value="<%= v('title') %>"></div>
      <div class="form-group">
        <label>Customer</label>
        <select class="input" name="customer_id">
          <option value="">— none —</option>
          <% customers.forEach(function(c){ %>
            <option value="<%= c.id %>" <%= (quote && quote.customer_id===c.id) || (preselectCustomer===c.id) ? 'selected' : '' %>><%= c.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="form-group">
        <label>Status</label>
        <select class="input" name="status">
          <% ['draft','sent','accepted','lost'].forEach(function(s){ %><option value="<%= s %>" <%= v('status')===s?'selected':'' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option><% }); %>
        </select>
      </div>
      <div class="form-group"><label>Issue date</label><input class="input" type="date" name="issue_date" value="<%= dateVal('issue_date') %>"></div>
      <div class="form-group"><label>Valid until</label><input class="input" type="date" name="valid_until" value="<%= dateVal('valid_until') %>"></div>
    </div>
  </div>

  <div class="card" style="padding:0;">
    <div class="card-header" style="padding:20px 24px 0;"><h2>Line items</h2></div>
    <div class="table-wrap">
      <table class="table" id="itemsTable">
        <thead><tr>
          <th style="min-width:160px;">Product / service</th><th style="min-width:180px;">Description</th><th>Supplier</th><th style="text-align:right;">Buy £</th>
          <th style="text-align:right;">Qty</th><th style="text-align:right;">Unit £</th><th style="text-align:right;">VAT %</th>
          <th style="text-align:right;">Line £</th><th></th>
        </tr></thead>
        <datalist id="prodList"></datalist>
        <tbody id="itemsBody">
          <% var rows = (items && items.length) ? items : [{}]; %>
          <% rows.forEach(function(it){ %>
            <tr class="item-row">
              <td><input class="input prod-search" list="prodList" value="<%= it.product_name || '' %>" placeholder="Search…" style="width:150px;"><input type="hidden" name="product_id[]" class="prod-id" value="<%= it.product_id || '' %>"></td>
              <td><input class="input" name="desc[]" value="<%= it.description || '' %>" style="width:100%;"></td>
              <td><input class="input" name="supplier[]" value="<%= it.supplier_name || '' %>" style="width:120px;"></td>
              <td><input class="input num-buy" name="buy[]" type="number" step="0.01" value="<%= it.buy_price!=null ? Number(it.buy_price) : '' %>" style="width:90px;text-align:right;"></td>
              <td><input class="input num-qty" name="qty[]" type="number" step="0.01" value="<%= it.quantity!=null ? Number(it.quantity) : 1 %>" style="width:80px;text-align:right;"></td>
              <td><input class="input num-price" name="price[]" type="number" step="0.01" value="<%= it.unit_price!=null ? Number(it.unit_price) : '' %>" style="width:100px;text-align:right;"></td>
              <td><input class="input num-tax" name="tax[]" type="number" step="0.01" value="<%= it.tax_rate!=null ? Number(it.tax_rate) : 20 %>" style="width:80px;text-align:right;"></td>
              <td style="text-align:right;" class="line-total">£0.00</td>
              <td><button type="button" class="btn remove-row">✕</button></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <div style="padding:12px 24px;border-top:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <button type="button" class="btn" id="addRow">+ Add line</button>
        <input class="input" id="catSearch" list="catList" placeholder="Add from catalogue…" style="min-width:220px;">
        <datalist id="catList"></datalist>
        <button type="button" class="btn" id="addFromCat">+ From catalogue</button>
      </div>
      <div style="text-align:right;font-size:14px;">
        <div class="muted">Subtotal: <span id="sumSub">£0.00</span></div>
        <div class="muted">VAT: <span id="sumTax">£0.00</span></div>
        <div style="font-weight:700;font-size:16px;">Total: <span id="sumTotal">£0.00</span></div>
        <div class="muted" style="margin-top:6px;">Cost: <span id="sumCost">£0.00</span> · Profit: <span id="sumProfit">£0.00</span> (<span id="sumMargin">0%</span>)</div>
      </div>
    </div>
  </div>

  <div class="card-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));align-items:start;">
    <div class="card"><div class="card-header"><h2>Notes</h2></div><textarea class="input" name="notes" rows="4" style="width:100%;"><%= v('notes') %></textarea></div>
    <div class="card"><div class="card-header"><h2>Terms</h2></div><textarea class="input" name="terms" rows="4" style="width:100%;"><%= v('terms') %></textarea></div>
  </div>

  <div style="display:flex;gap:10px;">
    <button class="btn btn-primary" type="submit"><%= isEdit ? 'Save quote' : 'Create quote' %></button>
    <a class="btn" href="<%= isEdit ? '/quotes/' + quote.id : '/quotes' %>">Cancel</a>
  </div>
</form>

<script>
  (function () {
    var body = document.getElementById('itemsBody');
    function money(x){ return '£' + (isNaN(x)?0:x).toFixed(2); }
    function recalc(){
      var sub = 0, tax = 0, cost = 0;
      body.querySelectorAll('.item-row').forEach(function(row){
        var q = parseFloat(row.querySelector('.num-qty').value) || 0;
        var p = parseFloat(row.querySelector('.num-price').value) || 0;
        var t = parseFloat(row.querySelector('.num-tax').value) || 0;
        var bEl = row.querySelector('.num-buy');
        var bv = bEl ? (parseFloat(bEl.value) || 0) : 0;
        var line = q * p;
        row.querySelector('.line-total').textContent = money(line);
        sub += line; tax += line * (t/100); cost += q * bv;
      });
      document.getElementById('sumSub').textContent = money(sub);
      document.getElementById('sumTax').textContent = money(tax);
      document.getElementById('sumTotal').textContent = money(sub + tax);
      var profit = sub - cost;
      document.getElementById('sumCost').textContent = money(cost);
      document.getElementById('sumProfit').textContent = money(profit);
      document.getElementById('sumMargin').textContent = (sub>0 ? (profit/sub*100).toFixed(1) : '0') + '%';
    }
    function addRow(){
      var first = body.querySelector('.item-row');
      var clone = first.cloneNode(true);
      clone.querySelectorAll('input').forEach(function(i){
        if (i.classList.contains('num-qty')) i.value = 1;
        else if (i.classList.contains('num-tax')) i.value = 20;
        else i.value = '';
      });
      body.appendChild(clone);
      return clone;
    }
    document.getElementById('addRow').addEventListener('click', function(){ addRow(); recalc(); });

    // Catalogue picker
    var catalogue = [];
    fetch('/products/catalogue.json').then(function(r){ return r.json(); }).then(function(rows){
      catalogue = rows;
      var dl = document.getElementById('catList');
      var pl = document.getElementById('prodList');
      rows.forEach(function(p){
        var o = document.createElement('option'); o.value = p.name; dl.appendChild(o);
        var o2 = document.createElement('option'); o2.value = p.name; pl.appendChild(o2);
      });
    }).catch(function(){});

    // Per-line product picker — selecting a product sets product_id + fills the row
    body.addEventListener('change', function(e){
      if (!e.target.classList.contains('prod-search')) return;
      var row = e.target.closest('.item-row');
      var p = catalogue.find(function(x){ return x.name === e.target.value; });
      if (!p) { row.querySelector('.prod-id').value = ''; return; }
      row.querySelector('.prod-id').value = p.id;
      var d = row.querySelector('[name="desc[]"]'); if (!d.value) d.value = p.description || p.name;
      var sup = row.querySelector('[name="supplier[]"]'); if (sup && !sup.value) sup.value = p.supplier || '';
      var buy = row.querySelector('.num-buy'); if (buy && !buy.value) buy.value = Number(p.cost_price) || 0;
      var pr = row.querySelector('.num-price'); if (!pr.value) pr.value = Number(p.unit_price) || 0;
      row.querySelector('.num-tax').value = Number(p.vat_rate) || 20;
      recalc();
    });
    document.getElementById('addFromCat').addEventListener('click', function(){
      var name = document.getElementById('catSearch').value.trim();
      if (!name) return;
      var p = catalogue.find(function(x){ return x.name === name; });
      if (!p) return;
      var row = addRow();
      row.querySelector('[name="desc[]"]').value = p.description || p.name;
      row.querySelector('.prod-id').value = p.id;
      row.querySelector('[name="supplier[]"]').value = p.supplier || '';
      row.querySelector('.num-buy').value = Number(p.cost_price) || 0;
      row.querySelector('.num-price').value = Number(p.unit_price) || 0;
      row.querySelector('.num-tax').value = Number(p.vat_rate) || 20;
      document.getElementById('catSearch').value = '';
      recalc();
    });
    body.addEventListener('input', recalc);
    body.addEventListener('click', function(e){
      if (e.target.classList.contains('remove-row')) {
        if (body.querySelectorAll('.item-row').length > 1) e.target.closest('.item-row').remove();
        else e.target.closest('.item-row').querySelectorAll('input').forEach(function(i){ if(!i.classList.contains('num-qty')&&!i.classList.contains('num-tax')) i.value=''; });
        recalc();
      }
    });
    recalc();
  })();
</script>

<%- include('../partials/footer') %>
