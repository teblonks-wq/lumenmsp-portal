<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, Helvetica, sans-serif; font-size: 13px; color: #374151; background: #fff; padding: 28px 32px; }
  table { border-collapse: collapse; }
  .lbl { font-size: 10px; font-weight: 700; color: #9ca3af; letter-spacing: .05em; text-transform: uppercase; }
  .val { font-size: 13px; color: #111827; }
</style>
</head>
<body>
<% function m(v){ return (Number(v)||0).toFixed(2); } %>
<% function d(x){ return x ? new Date(x).toLocaleDateString('en-GB', {day:'2-digit',month:'short',year:'numeric'}) : ''; } %>
<%
  var vatGroups = {};
  items.forEach(function(it){
    var net = Number(it.line_total)||0; var rate = Number(it.tax_rate)||0;
    var key = rate.toFixed(1);
    if(!vatGroups[key]) vatGroups[key] = { vat:0, net:0 };
    vatGroups[key].vat += net * (rate/100);
    vatGroups[key].net += net;
  });
  var addr = [quote.customer_name, quote.address_line_1, quote.address_line_2, quote.city, quote.county, quote.postcode].filter(Boolean);
%>

<!-- Header: logo left, company right -->
<table width="100%" style="margin-bottom:18px;"><tr>
  <td style="vertical-align:top;width:50%;">
    <% if (logoUrl) { %><img src="<%= logoUrl %>" alt="Lumen IT Solutions" style="display:block;max-width:180px;height:auto;border:0;"><% } %>
  </td>
  <td style="vertical-align:top;text-align:right;">
    <strong style="font-size:14px;color:#111827;">Lumen IT Solutions Limited</strong><br>
    <span style="font-size:12px;color:#6b7280;line-height:1.7;">
      Gemini House, Hargreaves Road<br>Groundwell Industrial Estate<br>Swindon, SN25 5AZ<br>
      back.office@lumensolutions.co.uk<br>VAT Registration No.: 443375688
    </span>
  </td>
</tr></table>

<h2 style="font-size:22px;font-weight:400;color:#9ca3af;margin:0 0 20px;">Quote</h2>

<!-- Quote To + meta -->
<table width="100%" style="margin-bottom:18px;"><tr>
  <td style="vertical-align:top;width:55%;">
    <div class="lbl" style="margin-bottom:6px;">Quote To</div>
    <div style="font-size:13px;line-height:1.7;color:#111827;"><%= addr.join(' · ') %></div>
  </td>
  <td style="vertical-align:top;text-align:right;">
    <table cellspacing="4" style="margin-left:auto;">
      <tr><td class="lbl" style="padding-right:20px;">Quote</td><td class="val"><%= quote.quote_number %></td></tr>
      <tr><td class="lbl" style="padding-right:20px;">Date</td><td class="val"><%= d(quote.issue_date) %></td></tr>
      <tr><td class="lbl" style="padding-right:20px;">Valid Until</td><td class="val"><%= d(quote.valid_until) %></td></tr>
    </table>
  </td>
</tr></table>

<!-- Line items -->
<table width="100%">
  <thead><tr style="border-top:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb;">
    <th style="padding:8px;text-align:left;" class="lbl">Item</th>
    <th style="padding:8px;text-align:left;" class="lbl">Description</th>
    <th style="padding:8px;text-align:center;" class="lbl">VAT</th>
    <th style="padding:8px;text-align:center;" class="lbl">Qty</th>
    <th style="padding:8px;text-align:right;" class="lbl">Rate</th>
    <th style="padding:8px;text-align:right;" class="lbl">Amount</th>
  </tr></thead>
  <tbody>
    <% items.forEach(function(it){ %>
      <tr>
        <td style="padding:10px 8px;border-bottom:1px dashed #e5e7eb;font-size:13px;color:#374151;"><%= it.product_name || '' %></td>
        <td style="padding:10px 8px;border-bottom:1px dashed #e5e7eb;font-size:13px;color:#374151;"><%= it.description %></td>
        <td style="padding:10px 8px;border-bottom:1px dashed #e5e7eb;font-size:13px;text-align:center;color:#374151;"><%= Number(it.tax_rate).toFixed(1) %>% S</td>
        <td style="padding:10px 8px;border-bottom:1px dashed #e5e7eb;font-size:13px;text-align:center;color:#374151;"><%= Number(it.quantity) %></td>
        <td style="padding:10px 8px;border-bottom:1px dashed #e5e7eb;font-size:13px;text-align:right;color:#374151;"><%= m(it.unit_price) %></td>
        <td style="padding:10px 8px;border-bottom:1px dashed #e5e7eb;font-size:13px;text-align:right;color:#374151;"><%= m(it.line_total) %></td>
      </tr>
    <% }); %>
  </tbody>
</table>

<!-- Totals -->
<table width="100%">
  <tr><td></td><td style="width:180px;text-align:right;padding:8px;font-size:12px;color:#6b7280;border-bottom:1px dashed #e5e7eb;text-transform:uppercase;letter-spacing:.04em;">Subtotal</td><td style="width:110px;text-align:right;padding:8px;font-size:13px;border-bottom:1px dashed #e5e7eb;"><%= m(quote.subtotal) %></td></tr>
  <tr><td></td><td style="text-align:right;padding:8px;font-size:12px;color:#6b7280;border-bottom:1px dashed #e5e7eb;text-transform:uppercase;letter-spacing:.04em;">VAT Total</td><td style="text-align:right;padding:8px;font-size:13px;border-bottom:1px dashed #e5e7eb;"><%= m(quote.tax_total) %></td></tr>
  <tr><td></td><td style="text-align:right;padding:10px 8px;font-size:12px;color:#6b7280;border-bottom:2px solid #111827;text-transform:uppercase;letter-spacing:.04em;font-weight:700;">Total (inc. VAT)</td><td style="text-align:right;padding:10px 8px;font-size:17px;font-weight:700;color:#111827;border-bottom:2px solid #111827;">£<%= m(quote.total) %></td></tr>
</table>

<% if (acceptUrl) { %>
<table width="100%" style="margin-top:20px;"><tr><td style="text-align:center;">
  <a href="<%= acceptUrl %>" style="display:inline-block;padding:11px 26px;background:#16a34a;color:#fff;text-decoration:none;border-radius:8px;font-weight:700;font-size:14px;margin:0 6px;">&#10003; Accept quote</a>
  <a href="<%= acceptUrl %>" style="display:inline-block;padding:11px 26px;background:#ffffff;color:#374151;text-decoration:none;border:1px solid #d1d5db;border-radius:8px;font-weight:700;font-size:14px;margin:0 6px;">&#10005; Decline</a>
  <div style="font-size:11px;color:#9ca3af;margin-top:8px;">Accept or decline online<% if (quote.valid_until) { %> — valid until <%= d(quote.valid_until) %><% } %>.</div>
</td></tr></table>
<% } %>

<% if (quote.notes) { %>
<div style="margin:16px 0;padding:12px 14px;border:1px solid #e5e7eb;border-radius:4px;font-size:12px;color:#6b7280;white-space:pre-wrap;"><%= quote.notes %></div>
<% } %>

<!-- VAT Summary -->
<div style="margin-top:18px;">
  <div style="font-size:11px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">VAT Summary</div>
  <table width="100%" style="border:1px solid #e5e7eb;border-radius:4px;overflow:hidden;">
    <thead><tr style="background:#f3f4f6;">
      <th style="padding:8px 12px;text-align:center;font-size:11px;font-weight:700;color:#374151;text-transform:uppercase;width:33%;">Rate</th>
      <th style="padding:8px 12px;text-align:right;font-size:11px;font-weight:700;color:#374151;text-transform:uppercase;width:33%;">VAT</th>
      <th style="padding:8px 12px;text-align:right;font-size:11px;font-weight:700;color:#374151;text-transform:uppercase;width:33%;">Net</th>
    </tr></thead>
    <tbody>
      <% Object.keys(vatGroups).forEach(function(k){ %>
        <tr><td style="padding:8px 12px;font-size:13px;text-align:center;">VAT @ <%= k %>%</td><td style="padding:8px 12px;font-size:13px;text-align:right;"><%= m(vatGroups[k].vat) %></td><td style="padding:8px 12px;font-size:13px;text-align:right;"><%= m(vatGroups[k].net) %></td></tr>
      <% }); %>
    </tbody>
  </table>
</div>

<div style="margin-top:18px;padding-top:14px;border-top:1px solid #e5e7eb;font-size:10px;color:#9ca3af;line-height:1.6;">
  LumenMSP is a trading name of Lumen IT Solutions Limited. Registered in England &amp; Wales · Company No. 14951068 · Gemini House, Hargreaves Road, Groundwell Industrial Estate, Swindon, SN25 5AZ
</div>
</body>
</html>
