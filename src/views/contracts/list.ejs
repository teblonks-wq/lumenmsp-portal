<%- include('../partials/header', { title: 'Contracts', user }) %>
<% function money(v){ return '£' + (Number(v)||0).toFixed(2); } %>
<% function badge(s){ return s==='active'?'badge-sent':s==='draft'?'badge-inactive':s==='expired'?'badge-failed':'badge-failed'; } %>

<div class="page-header" style="display:flex;align-items:flex-end;justify-content:space-between;gap:16px;flex-wrap:wrap;">
  <div><h1>Contracts</h1><p class="muted"><%= contracts.length %> shown</p></div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
    <form method="get" action="/contracts" style="display:flex;gap:8px;align-items:center;">
      <input class="input" type="search" name="search" value="<%= search %>" placeholder="Search number, title, customer…" style="min-width:240px;">
      <% if (status) { %><input type="hidden" name="status" value="<%= status %>"><% } %>
      <button class="btn" type="submit">Search</button>
      <% if (search) { %><a class="btn" href="/contracts<%= status ? '?status=' + status : '' %>">Clear</a><% } %>
    </form>
    <a class="btn btn-primary" href="/contracts/new">+ New contract</a>
  </div>
</div>

<div class="tabs" style="margin-bottom:16px;">
  <a class="tab-btn <%= status==='' ? 'active' : '' %>" href="/contracts">All</a>
  <% ['draft','active','expired','cancelled'].forEach(function(s){ %>
    <a class="tab-btn <%= status===s ? 'active' : '' %>" href="/contracts?status=<%= s %>"><%= s.charAt(0).toUpperCase()+s.slice(1) %> <span class="muted">(<%= statusCounts[s]||0 %>)</span></a>
  <% }); %>
</div>

<div class="card" style="padding:0;">
  <div class="table-wrap">
    <table class="table">
      <thead><tr><th>Number</th><th>Title</th><th>Customer</th><th>Service</th><th>Status</th><th>Term</th><th style="text-align:right;">Monthly</th></tr></thead>
      <tbody>
        <% if (contracts.length===0) { %><tr><td colspan="7"><div class="empty-state">No contracts.</div></td></tr><% } %>
        <% contracts.forEach(function(ct){ %>
          <tr>
            <td><a class="row-link" href="/contracts/<%= ct.id %>"><%= ct.contract_number %></a></td>
            <td><%= ct.title %></td>
            <td class="muted"><% if (ct.customer_id) { %><a class="row-link" href="/customers/<%= ct.customer_id %>"><%= ct.customer_name %></a><% } else { %>—<% } %></td>
            <td class="muted"><%= ct.service_type %></td>
            <td><span class="badge <%= badge(ct.status) %>"><%= ct.status.charAt(0).toUpperCase()+ct.status.slice(1) %></span></td>
            <td class="muted"><%= ct.start_date ? new Date(ct.start_date).toLocaleDateString('en-GB') : '—' %><% if (ct.end_date) { %> → <%= new Date(ct.end_date).toLocaleDateString('en-GB') %><% } %></td>
            <td style="text-align:right;"><%= money(ct.monthly_total) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
