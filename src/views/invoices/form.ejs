<%- include('../partials/header', { title: invoice && invoice.id ? 'Edit invoice' : 'New invoice', user }) %>

<% var isEdit = invoice && invoice.id; %>
<% function v(f){ return invoice && invoice[f] != null ? invoice[f] : ''; } %>
<% function dateVal(f){ if(!invoice || !invoice[f]) return ''; try { return new Date(invoice[f]).toISOString().slice(0,10); } catch(e){ return invoice[f]; } } %>

<div class="page-header">
  <p class="muted" style="margin:0 0 4px;"><a class="row-link" href="<%= isEdit ? '/invoices/' + invoice.id : '/invoices' %>">← Back</a></p>
  <h1><%= isEdit ? 'Edit invoice' : 'New invoice' %></h1>
</div>

<% if (error) { %><div class="alert alert-error" style="max-width:900px;"><%= error %></div><% } %>

<form method="post" action="<%= isEdit ? '/invoices/' + invoice.id : '/invoices' %>">
  <% if (invoice && invoice.quote_id) { %><input type="hidden" name="quote_id" value="<%= invoice.quote_id %>"><% } %>
  <div class="card">
    <div class="card-header"><h2>Details</h2></div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">
      <div class="form-group" style="grid-column:1 / -1;"><label>Title *</label><input class="input" name="title" required value="<%= v('title') %>"></div>
      <div class="form-group">
        <label>Customer</label>
        <select class="input" name="customer_id">
          <option value="">— none —</option>
          <% customers.forEach(function(c){ %><option value="<%= c.id %>" <%= (invoice && invoice.customer_id===c.id) || (preselectCustomer===c.id) ? 'selected' : '' %>><%= c.name %></option><% }); %>
        </select>
      </div>
      <div class="form-group"><label>Scheme</label><select class="input" name="invoice_scheme"><% ['IT','CS'].forEach(function(s){ %><option value="<%= s %>" <%= v('invoice_scheme')===s?'selected':'' %>><%= s %></option><% }); %></select></div>
      <div class="form-group"><label>Service type (contract)</label>
        <select class="input" name="contract_type">
          <% ['','IT','Comms'].forEach(function(s){ %><option value="<%= s %>" <%= v('contract_type')===s?'selected':'' %>><%= s===''?'None':(s==='IT'?'IT — pulls Giacom cloud':'Comms — pulls call charges') %></option><% }); %>
        </select>
      </div>
      <div class="form-group"><label>Payment method</label><input class="input" name="payment_method" value="<%= v('payment_method') || 'upfront' %>"></div>
      <div class="form-group"><label>Issue date</label><input class="input" type="date" name="issue_date" value="<%= dateVal('issue_date') %>"></div>
      <div class="form-group"><label>Due date</label><input class="input" type="date" name="due_date" value="<%= dateVal('due_date') %>"></div>
    </div>
  </div>

  <div class="card" style="padding:0;">
    <div class="card-header" style="padding:20px 24px 0;"><h2>Line items</h2></div>
    <div class="table-wrap">
      <table class="table" id="itemsTable" style="table-layout:fixed;width:100%;">
        <colgroup>
          <col style="width:26%;"><col style="width:31%;"><col style="width:9%;"><col style="width:12%;"><col style="width:8%;"><col style="width:9%;"><col style="width:5%;">
        </colgroup>
        <thead><tr><th>Product / service</th><th>Description</th><th style="text-align:right;">Qty</th><th style="text-align:right;">Unit £</th><th style="text-align:right;">VAT %</th><th style="text-align:right;">Line £</th><th></th></tr></thead>
        <datalist id="prodList"></datalist>
        <tbody id="itemsBody">
          <% var rows = (items && items.length) ? items : [{}]; %>
          <% rows.forEach(function(it){ %>
            <tr class="item-row">
              <td><input class="input prod-search" list="prodList" value="<%= it.product_name || '' %>" placeholder="Search…" style="width:100%;box-sizing:border-box;"><input type="hidden" name="product_id[]" class="prod-id" value="<%= it.product_id || '' %>"><input type="hidden" name="source[]" class="line-source" value="<%= it.source || 'manual' %>"><input type="hidden" name="sync_ref[]" value="<%= it.sync_ref || '' %>"><input type="hidden" name="sync_locked[]" value="<%= it.sync_locked ? '1' : '' %>"><input type="hidden" name="one_off[]" value="<%= it.is_one_off ? '1' : '' %>"><input type="hidden" name="prev_qty[]" value="<%= it.quantity!=null ? Number(it.quantity) : 1 %>"><input type="hidden" name="prev_price[]" value="<%= it.unit_price!=null ? Number(it.unit_price) : '' %>"><input type="hidden" name="prev_desc[]" value="<%= it.description || '' %>"><div class="line-badges"><% if (it.source==='giacom') { %><span class="badge" style="background:#dbeafe;color:#1e40af;font-size:9px;">🔄 Synced<%= it.sync_locked ? ' · override' : '' %></span><% if (it.sync_drift) { %><div class="muted" style="font-size:9px;color:#92400e;">⚠ <%= it.sync_drift %></div><% } %><% } else if (it.source && it.source!=='manual') { %><span class="muted" style="font-size:10px;">auto: <%= it.source %></span><% } %></div></td>
              <td><input class="input" name="desc[]" value="<%= it.description || '' %>" style="width:100%;box-sizing:border-box;"></td>
              <td><input class="input num-qty" name="qty[]" type="number" step="0.01" value="<%= it.quantity!=null ? Number(it.quantity) : 1 %>" style="width:100%;box-sizing:border-box;text-align:right;"></td>
              <td><input class="input num-price" name="price[]" type="number" step="0.01" value="<%= it.unit_price!=null ? Number(it.unit_price) : '' %>" style="width:100%;box-sizing:border-box;text-align:right;"></td>
              <td><input class="input num-tax" name="tax[]" type="number" step="0.01" value="<%= it.tax_rate!=null ? Number(it.tax_rate) : 20 %>" style="width:100%;box-sizing:border-box;text-align:right;"></td>
              <td style="text-align:right;vertical-align:middle;font-variant-numeric:tabular-nums;" class="line-total">£0.00</td>
              <td><button type="button" class="btn remove-row">✕</button></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <div style="padding:12px 24px;border-top:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <button type="button" class="btn" id="addRow">+ Add line</button>
        <input class="input" id="catSearch" list="catList" placeholder="Add from catalogue…" style="min-width:220px;">
        <datalist id="catList"></datalist>
        <button type="button" class="btn" id="addFromCat">+ From catalogue</button>
      </div>
      <div style="text-align:right;">
        <div class="muted" style="font-size:13px;">Subtotal <span id="sumSub" style="font-variant-numeric:tabular-nums;">£0.00</span> &nbsp;·&nbsp; VAT <span id="sumTax" style="font-variant-numeric:tabular-nums;">£0.00</span></div>
        <div style="margin-top:4px;"><span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#0ea5b7;">Total</span>
          <span id="sumTotal" style="font-size:26px;font-weight:800;color:#0f172a;font-variant-numeric:tabular-nums;margin-left:8px;">£0.00</span></div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header"><h2>Recurring billing</h2></div>
    <p class="muted" style="margin:0 0 12px;font-size:13px;">Make this a monthly template. On the generate day it clones into a fresh invoice (IT pulls Giacom cloud, Comms pulls call charges — set the service type above).</p>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:12px;">
      <div class="form-group"><label>Template name</label><input class="input" name="recurring_name" value="<%= v('recurring_name') %>"></div>
      <div class="form-group"><label>Generate &amp; collect on day</label><input class="input" type="number" min="1" max="28" name="send_day" value="<%= v('send_day') || 23 %>"></div>
      <div class="form-group"><label>Invoice/due day</label><input class="input" type="number" min="1" max="28" name="due_day" value="<%= v('due_day') || 1 %>"></div>
    </div>
    <div style="display:flex;flex-direction:column;gap:7px;">
      <label style="display:flex;gap:8px;align-items:center;"><input type="checkbox" name="is_recurring" <%= invoice && invoice.is_recurring ? 'checked' : '' %>> <strong>Recurring</strong></label>
      <label style="display:flex;gap:8px;align-items:center;"><input type="checkbox" name="recurring_active" <%= !invoice || invoice.recurring_active===undefined || invoice.recurring_active ? 'checked' : '' %>> Active (uncheck to pause)</label>
      <label style="display:flex;gap:8px;align-items:center;"><input type="checkbox" name="auto_send" <%= invoice && invoice.auto_send ? 'checked' : '' %>> Automatically send emails</label>
      <label style="display:flex;gap:8px;align-items:center;"><input type="checkbox" name="auto_qb" <%= invoice && invoice.auto_qb ? 'checked' : '' %>> Auto-push to QuickBooks</label>
      <label style="display:flex;gap:8px;align-items:center;"><input type="checkbox" name="auto_gc" <%= invoice && invoice.auto_gc ? 'checked' : '' %>> Auto-submit to GoCardless</label>
    </div>
  </div>

  <div class="card-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));align-items:start;">
    <div class="card"><div class="card-header"><h2>Notes</h2></div><textarea class="input" name="notes" rows="4" style="width:100%;"><%= v('notes') %></textarea></div>
    <div class="card"><div class="card-header"><h2>Terms</h2></div><textarea class="input" name="terms" rows="4" style="width:100%;"><%= v('terms') %></textarea></div>
  </div>

  <div style="display:flex;gap:10px;">
    <button class="btn btn-primary" type="submit"><%= isEdit ? 'Save invoice' : 'Create invoice' %></button>
    <a class="btn" href="<%= isEdit ? '/invoices/' + invoice.id : '/invoices' %>">Cancel</a>
  </div>
</form>

<script>
  (function () {
    var body = document.getElementById('itemsBody');
    function money(x){ return '£' + (isNaN(x)?0:x).toFixed(2); }
    function recalc(){
      var sub = 0, tax = 0;
      body.querySelectorAll('.item-row').forEach(function(row){
        var q = parseFloat(row.querySelector('.num-qty').value) || 0;
        var p = parseFloat(row.querySelector('.num-price').value) || 0;
        var t = parseFloat(row.querySelector('.num-tax').value) || 0;
        var line = q * p;
        row.querySelector('.line-total').textContent = money(line);
        sub += line; tax += line * (t/100);
      });
      document.getElementById('sumSub').textContent = money(sub);
      document.getElementById('sumTax').textContent = money(tax);
      document.getElementById('sumTotal').textContent = money(sub + tax);
    }
    function addRow(){
      var clone = body.querySelector('.item-row').cloneNode(true);
      clone.querySelectorAll('input').forEach(function(i){
        if (i.classList.contains('num-qty')) i.value = 1;
        else if (i.classList.contains('num-tax')) i.value = 20;
        else if (i.classList.contains('line-source')) i.value = 'manual'; // new lines are manual
        else i.value = '';
      });
      var lb = clone.querySelector('.line-badges'); if (lb) lb.innerHTML = ''; // new lines are manual — clear synced/auto badges
      body.appendChild(clone);
      return clone;
    }
    document.getElementById('addRow').addEventListener('click', function(){ addRow(); recalc(); });

    // Catalogue picker
    var catalogue = [];
    fetch('/products/catalogue.json').then(function(r){ return r.json(); }).then(function(rows){
      catalogue = rows;
      var dl = document.getElementById('catList');
      var pl = document.getElementById('prodList');
      rows.forEach(function(p){
        var o = document.createElement('option'); o.value = p.name; dl.appendChild(o);
        var o2 = document.createElement('option'); o2.value = p.name; pl.appendChild(o2);
      });
    }).catch(function(){});

    // Per-line product picker — selecting a product sets product_id + fills the row
    body.addEventListener('change', function(e){
      if (!e.target.classList.contains('prod-search')) return;
      var row = e.target.closest('.item-row');
      var p = catalogue.find(function(x){ return x.name === e.target.value; });
      if (!p) { row.querySelector('.prod-id').value = ''; return; }
      row.querySelector('.prod-id').value = p.id;
      // Line description = the product's clean customer-facing spec (falls back to name).
      row.querySelector('[name="desc[]"]').value = p.description || p.name;
      var pr = row.querySelector('.num-price'); if (!pr.value) pr.value = Number(p.unit_price) || 0;
      row.querySelector('.num-tax').value = Number(p.vat_rate) || 20;
      recalc();
    });
    document.getElementById('addFromCat').addEventListener('click', function(){
      var name = document.getElementById('catSearch').value.trim();
      if (!name) return;
      var p = catalogue.find(function(x){ return x.name === name; });
      if (!p) return;
      var row = addRow();
      row.querySelector('[name="desc[]"]').value = p.description || p.name;
      row.querySelector('.prod-id').value = p.id;
      row.querySelector('.num-price').value = Number(p.unit_price) || 0;
      row.querySelector('.num-tax').value = Number(p.vat_rate) || 20;
      document.getElementById('catSearch').value = '';
      recalc();
    });
    body.addEventListener('input', recalc);
    body.addEventListener('click', function(e){
      if (e.target.classList.contains('remove-row')) {
        if (body.querySelectorAll('.item-row').length > 1) e.target.closest('.item-row').remove();
        else e.target.closest('.item-row').querySelectorAll('input').forEach(function(i){ if(!i.classList.contains('num-qty')&&!i.classList.contains('num-tax')) i.value=''; });
        recalc();
      }
    });
    recalc();
  })();
</script>

<%- include('../partials/footer') %>
