<%- include('../partials/header', { title: 'Message', user }) %>
<% var path = { quote:'/quotes/', invoice:'/invoices/', customer:'/customers/' }; %>

<div class="page-header">
  <p class="muted" style="margin:0 0 4px;"><a class="row-link" href="/mail">← Mail</a></p>
  <h1 style="margin:0;"><%= m.subject || '(no subject)' %></h1>
</div>

<div class="card" style="max-width:820px;">
  <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;border-bottom:1px solid var(--line);padding-bottom:12px;margin-bottom:14px;">
    <div>
      <div style="font-weight:600;"><%= m.from_name || m.from_email || '—' %></div>
      <% if (m.from_email) { %><div class="muted" style="font-size:13px;"><%= m.from_email %></div><% } %>
      <% if (path[m.entity_type]) { %><div style="font-size:13px;margin-top:4px;">On <a class="row-link" href="<%= path[m.entity_type] %><%= m.entity_id %>#comms"><%= m.entity_type %> #<%= m.entity_id %></a></div><% } %>
    </div>
    <div class="muted" style="font-size:13px;text-align:right;"><%= new Date(m.created_at).toLocaleString('en-GB') %></div>
  </div>

  <div class="email-body" style="line-height:1.6;overflow-wrap:anywhere;"><%- m.body || '(no content)' %></div>
</div>
<style>
  .email-body { overflow-x:auto; } .email-body img { max-width:100%; height:auto; }
  .email-body table { max-width:100%; } .email-body a { word-break:break-word; }
</style>

<div class="card" style="max-width:820px;">
  <div class="card-header"><h2>Reply</h2></div>
  <form method="post" action="/comms/<%= m.id %>/reply" enctype="multipart/form-data"
        onsubmit="document.getElementById('replyBody').value = window.replyQuill.root.innerHTML;">
    <input type="hidden" name="body" id="replyBody">
    <div class="form-group"><label>To</label><input class="input" value="<%= m.from_email || '' %>" disabled style="width:100%;max-width:420px;"></div>
    <div class="form-group"><label>Message</label><div id="replyEditor" style="height:170px;background:#fff;"></div></div>
    <div class="form-group"><label>Attachments <span class="muted">(up to 5, 10MB each)</span></label><input class="input" type="file" name="attachments" multiple></div>
    <button class="btn btn-primary" type="submit"<%= m.from_email ? '' : ' disabled' %>>Send reply</button>
    <% if (!m.from_email) { %><span class="muted" style="margin-left:8px;">No sender address to reply to.</span><% } %>
  </form>
</div>

<div class="card" style="max-width:820px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
  <form method="post" action="/comms/<%= m.id %>/to-ticket" style="display:inline;">
    <button class="btn" type="submit">Transfer to support →</button>
  </form>
  <span class="muted" style="font-size:13px;">Creates a support ticket from this email, assigned to you.</span>
  <form method="post" action="/comms/<%= m.id %>/delete" style="display:inline;margin-left:auto;" onsubmit="return confirm('Delete this message?');">
    <button class="btn" type="submit">Delete</button>
  </form>
</div>

<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script src="/static/grammar.js"></script>
<script>
  window.replyQuill = new Quill('#replyEditor', {
    theme: 'snow',
    placeholder: 'Type your reply… (your signature is added automatically)',
    modules: { toolbar: [
      [{ font: [] }, { size: [] }],
      ['bold', 'italic', 'underline', 'strike'],
      [{ color: [] }, { background: [] }],
      [{ list: 'ordered' }, { list: 'bullet' }],
      ['link'],
      ['clean'],
    ] },
  });
  if (window.LumenGrammar) LumenGrammar.attach(window.replyQuill, document.getElementById('replyEditor').parentNode);
</script>

<%- include('../partials/footer') %>
