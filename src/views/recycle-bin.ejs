<%- include('partials/header', { title: 'Recycle bin', user }) %>
<% function dt(x){ return x ? new Date(x).toLocaleString('en-GB') : ''; } %>

<div class="page-header">
  <p class="muted" style="margin:0 0 4px;"><a class="row-link" href="/admin">← Admin</a></p>
  <h1>Recycle bin</h1>
  <p class="muted">Deleted items are kept here. Restore them, or empty a section to remove them for good.</p>
</div>

<% if (error) { %><div class="alert alert-error" style="max-width:900px;"><%= error %></div><% } %>

<% sections.forEach(function(s){ %>
  <div class="card" style="padding:0;margin-bottom:18px;">
    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;">
      <h2 style="margin:0;"><%= s.label %> <span class="muted" style="font-weight:400;font-size:14px;">(<%= s.rows.length %>)</span></h2>
      <% if (s.rows.length) { %>
      <form method="post" action="/recycle-bin/<%= s.key %>/empty" onsubmit="return confirm('Permanently delete all <%= s.rows.length %> item(s) in <%= s.label %>? This cannot be undone.');" style="margin:0;">
        <button class="btn" type="submit" style="color:var(--lumen-dark);">Empty <%= s.label %></button>
      </form>
      <% } %>
    </div>
    <% if (s.rows.length===0) { %>
      <div style="padding:14px 16px;" class="muted">Nothing deleted.</div>
    <% } else { %>
      <div class="table-wrap">
        <table class="table">
          <thead><tr><th>Item</th><th>Deleted</th><th>By</th><th></th></tr></thead>
          <tbody>
            <% s.rows.forEach(function(r){ %>
              <tr>
                <td><% if (r.href) { %><a class="row-link" href="<%= r.href %>"><strong><%= r.title || ('#' + r.id) %></strong></a><% } else { %><strong><%= r.title || ('#' + r.id) %></strong><% } %><% if (r.sub) { %> <span class="muted" style="font-size:12px;">· <%= r.sub %></span><% } %></td>
                <td class="muted" style="font-size:12px;white-space:nowrap;"><%= dt(r.deleted_at) %></td>
                <td class="muted" style="font-size:12px;"><%= r.deleted_by || '—' %></td>
                <td style="text-align:right;">
                  <form method="post" action="/recycle-bin/<%= s.key %>/<%= r.id %>/restore" style="display:inline;"><button class="btn" type="submit">Restore</button></form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
<% }); %>

<%- include('partials/footer') %>
