<%- include('partials/header', { title: 'Back Office Reports', user }) %>
<% function money(v){ return '£' + (Number(v)||0).toLocaleString('en-GB',{minimumFractionDigits:2,maximumFractionDigits:2}); } %>

<div class="page-header"><p class="muted" style="margin:0 0 4px;"><a class="row-link" href="/bureau">← Back Office</a></p>
  <h1>Back Office Reports</h1></div>

<div class="card" style="display:flex;gap:28px;flex-wrap:wrap;margin-bottom:16px;">
  <div><div class="muted" style="font-size:12px;">Monthly sale</div><div style="font-size:20px;font-weight:800;"><%= money(totals.sale) %></div></div>
  <div><div class="muted" style="font-size:12px;">Cost</div><div style="font-size:20px;font-weight:800;color:#64748b;"><%= money(totals.cost) %></div></div>
  <div><div class="muted" style="font-size:12px;">Margin</div><div style="font-size:20px;font-weight:800;color:#166534;"><%= money(totals.profit) %></div></div>
</div>

<div class="tabs" style="margin:0 0 14px;">
  <button class="tab-btn active" data-rtab="cust">Profit by customer</button>
  <button class="tab-btn" data-rtab="cat">By product / category</button>
  <button class="tab-btn" data-rtab="watch">Watchlist <% if (unallocCount || uncosted.length || oneOffs.length) { %>(<%= unallocCount + uncosted.length + oneOffs.length %>)<% } %></button>
  <button class="tab-btn" data-rtab="reg">CLI / service register</button>
</div>

<!-- Profit by customer -->
<div class="rtab" data-rtab="cust">
  <div class="card" style="padding:0;">
    <div style="padding:8px 20px 4px;"><input class="input card-filter" placeholder="Search customer…" style="max-width:260px;font-size:13px;padding:5px 8px;"></div>
    <div class="table-wrap"><table class="table sortable">
      <thead><tr><th>Customer</th><th style="text-align:right;">Sale /mo</th><th style="text-align:right;">Cost /mo</th><th style="text-align:right;">Profit /mo</th><th style="text-align:right;">Margin %</th><th style="text-align:right;">Uncosted</th></tr></thead>
      <tbody>
        <% profitByCustomer.forEach(function(c){ var m = c.sale? (c.profit/c.sale*100):0; %>
        <tr>
          <td><%= c.name %></td>
          <td style="text-align:right;"><%= money(c.sale) %></td>
          <td style="text-align:right;" class="muted"><%= money(c.cost) %></td>
          <td style="text-align:right;font-weight:600;color:<%= c.profit>=0?'#166534':'#b91c1c' %>;"><%= money(c.profit) %></td>
          <td style="text-align:right;" data-sort="<%= m.toFixed(1) %>"><%= m.toFixed(0) %>%</td>
          <td style="text-align:right;"><% if (c.uncosted) { %><span class="badge" style="font-size:10px;background:#fef3c7;color:#92400e;"><%= c.uncosted %></span><% } else { %>—<% } %></td>
        </tr>
        <% }); %>
      </tbody>
    </table></div>
  </div>
</div>

<!-- By product / category -->
<div class="rtab" data-rtab="cat" style="display:none;">
  <div class="card" style="padding:0;"><div class="table-wrap"><table class="table sortable">
    <thead><tr><th>Category</th><th style="text-align:right;">Sale /mo</th><th style="text-align:right;">Cost /mo</th><th style="text-align:right;">Profit /mo</th><th style="text-align:right;">Margin %</th></tr></thead>
    <tbody>
      <% profitByCategory.forEach(function(c){ var m = c.sale? (c.profit/c.sale*100):0; %>
      <tr>
        <td><strong><%= c.label %></strong></td>
        <td style="text-align:right;"><%= money(c.sale) %></td>
        <td style="text-align:right;" class="muted"><%= money(c.cost) %></td>
        <td style="text-align:right;font-weight:600;color:<%= c.profit>=0?'#166534':'#b91c1c' %>;"><%= money(c.profit) %></td>
        <td style="text-align:right;" data-sort="<%= m.toFixed(1) %>"><%= m.toFixed(0) %>%</td>
      </tr>
      <% }); %>
    </tbody>
  </table></div></div>
</div>

<!-- Watchlist -->
<div class="rtab" data-rtab="watch" style="display:none;">
  <div class="card" style="margin-bottom:14px;border-left:3px solid #f59e0b;">
    <strong><%= unallocCount %></strong> unallocated CLI(s) · cost <%= money(unallocCost) %> —
    <a class="row-link" href="/bureau/bill-run">allocate in the bill run →</a>
  </div>
  <h3 style="margin:14px 0 6px;">Uncosted services <span class="muted">(<%= uncosted.length %>)</span></h3>
  <div class="card" style="padding:0;margin-bottom:18px;"><div class="table-wrap"><table class="table sortable">
    <thead><tr><th>Customer</th><th>Product</th><th>Source</th><th style="text-align:right;">Buy /mo</th></tr></thead>
    <tbody>
      <% if (!uncosted.length) { %><tr><td colspan="4"><div class="empty-state">Everything mapped is priced. 🎉</div></td></tr><% } %>
      <% uncosted.forEach(function(l){ %><tr><td><%= l.customer_name||'—' %></td><td><%= l.description||l.product_reference||'(unnamed)' %></td><td class="muted"><%= l.source %></td><td style="text-align:right;" data-sort="<%= (l.unit_cost*l.quantity).toFixed(2) %>"><%= money(l.unit_cost*l.quantity) %></td></tr><% }); %>
    </tbody>
  </table></div></div>
  <h3 style="margin:14px 0 6px;">Unbilled one-off charges <span class="muted">(<%= oneOffs.length %>)</span></h3>
  <div class="card" style="padding:0;"><div class="table-wrap"><table class="table sortable">
    <thead><tr><th>Customer</th><th>Charge</th><th style="text-align:right;">Cost</th></tr></thead>
    <tbody>
      <% if (!oneOffs.length) { %><tr><td colspan="3"><div class="empty-state">No outstanding one-offs.</div></td></tr><% } %>
      <% oneOffs.forEach(function(o){ %><tr><td><%= o.customer||'—' %></td><td><%= o.description %></td><td style="text-align:right;" data-sort="<%= Number(o.cost).toFixed(2) %>"><%= money(o.cost) %></td></tr><% }); %>
    </tbody>
  </table></div></div>
</div>

<!-- CLI / service register -->
<div class="rtab" data-rtab="reg" style="display:none;">
  <div class="card">
    <p style="margin:0 0 12px;">Download the full CLI / service register — every line per customer with cost, current sale and service dates, for the period you choose. Open it in Excel and filter to a customer for an on-demand CLI report.</p>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <a class="btn btn-primary" href="/bureau/pricing-detail.csv?source=comms">Comms register (CSV)</a>
      <a class="btn" href="/bureau/pricing-detail.csv?source=giacom">Cloud register (CSV)</a>
      <a class="btn" href="/bureau/customer-charges.csv">Everything we sell (CSV)</a>
    </div>
  </div>
</div>

<script>(function(){
  var btns=[].slice.call(document.querySelectorAll('[data-rtab]')).filter(function(b){return b.tagName==='BUTTON';});
  var panels=[].slice.call(document.querySelectorAll('div.rtab'));
  btns.forEach(function(b){b.addEventListener('click',function(){
    var k=b.getAttribute('data-rtab');
    btns.forEach(function(x){x.classList.toggle('active',x===b);});
    panels.forEach(function(p){p.style.display=p.getAttribute('data-rtab')===k?'':'none';});
  });});
})();</script>

<%- include('partials/footer') %>
