<%- include('header', { title: 'Wallboard', user, active: 'wallboard', company: typeof company !== 'undefined' ? company : '' }) %>

<div class="page-header" style="margin-bottom:14px;">
  <h1 style="margin:0;font-size:26px;letter-spacing:-.5px;">Wallboard</h1>
  <p class="muted" style="margin:4px 0 0;">A live board for a TV — one site, big numbers, updates itself. Pick your site and tiles, then launch.</p>
</div>

<div class="card" style="max-width:760px;">
  <form id="wbForm" onsubmit="return wbLaunch(event)">
    <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;margin-bottom:4px;">Site</label>
    <select class="input" id="wbSite" style="min-width:280px;">
      <% sites.forEach(function(s){ %>
        <option value="<%= s.id %>" <%= s.configured ? '' : 'disabled' %>><%= s.label %><%= s.configured ? '' : ' — not set up yet' %></option>
      <% }); %>
    </select>

    <div style="margin-top:18px;">
      <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;">Tiles</span>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:8px;margin-top:8px;">
        <% modules.forEach(function(m){ %>
          <label style="display:flex;gap:9px;align-items:flex-start;border:1px solid #e2e8f0;border-radius:8px;padding:10px 12px;cursor:pointer;">
            <input type="checkbox" class="wb-mod" value="<%= m.key %>" <%= defaults.indexOf(m.key) >= 0 ? 'checked' : '' %> style="width:auto;min-width:auto;margin-top:2px;">
            <span><strong style="font-size:14px;"><%= m.label %></strong><br><span class="muted" style="font-size:12px;"><%= m.desc %></span></span>
          </label>
        <% }); %>
      </div>
    </div>

    <div style="margin-top:18px;display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap;">
      <div>
        <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;margin-bottom:4px;">Refresh every</label>
        <select class="input" id="wbRefresh"><option value="30">30 seconds</option><option value="60" selected>60 seconds</option><option value="120">2 minutes</option><option value="300">5 minutes</option></select>
      </div>
      <div>
        <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;margin-bottom:4px;">Run for</label>
        <select class="input" id="wbHours">
          <% [1,2,3,4,6,8,10,12].forEach(function(h){ %><option value="<%= h %>" <%= h===8 ? 'selected' : '' %>><%= h %> hour<%= h>1?'s':'' %></option><% }); %>
        </select>
      </div>
      <button class="btn btn-primary" type="submit" style="font-size:15px;">Launch Wallboard</button>
    </div>
    <p class="muted" style="font-size:12px;margin:12px 0 0;">Opens in a new tab — press F11 on the TV browser for full screen. Numbers refresh in place; the page never reloads, and the board keeps your sign-in alive while it runs. When the run-for timer ends the board stops and asks to be restarted.</p>
  </form>
</div>

<script>
function wbLaunch(e){
  e.preventDefault();
  var site = document.getElementById('wbSite').value;
  var mods = Array.prototype.slice.call(document.querySelectorAll('.wb-mod:checked')).map(function(c){ return c.value; }).join(',');
  var ref = document.getElementById('wbRefresh').value;
  if (!site) return false;
  var hrs = document.getElementById('wbHours').value;
  window.open('/my/wallboard/tv?site=' + site + '&modules=' + encodeURIComponent(mods) + '&refresh=' + ref + '&hours=' + hrs, '_blank');
  return false;
}
</script>

<%- include('footer') %>
