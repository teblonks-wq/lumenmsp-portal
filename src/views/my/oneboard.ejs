<%- include('header', { title: 'OneBoard', user, active: 'oneboard', company: typeof company !== 'undefined' ? company : '' }) %>
<%
  function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c];}); }
  // Sequential single-hue scale (light → deep teal) for the missed-calls heatmap.
  var HEAT_STEPS = ['#f8fafc','#d7eef3','#a5dbe6','#5cb8ca','#1f8fa6','#0e6377'];
  function heatBg(n){ if(!maxHeat || !n) return HEAT_STEPS[0]; var i = Math.min(5, Math.max(1, Math.ceil(n / maxHeat * 5))); return HEAT_STEPS[i]; }
  function heatInk(n){ if(!maxHeat || !n) return '#94a3b8'; return (Math.ceil(n / maxHeat * 5) >= 4) ? '#ffffff' : '#0f172a'; }
  // Second sequential single-hue scale (light -> deep indigo) for the ALL-calls heatmap,
  // so it can never be mistaken for the missed-calls teal at a glance.
  var HEAT_ALL = ['#f8fafc','#e0e7ff','#c7d2fe','#818cf8','#4f46e5','#312e81'];
  function heatAllBg(n){ if(!maxHeatAll || !n) return HEAT_ALL[0]; var i = Math.min(5, Math.max(1, Math.ceil(n / maxHeatAll * 5))); return HEAT_ALL[i]; }
  function heatAllInk(n){ if(!maxHeatAll || !n) return '#94a3b8'; return (Math.ceil(n / maxHeatAll * 5) >= 4) ? '#ffffff' : '#0f172a'; }
  function delta(cur, prev, invert){
    if (prev == null) return '';
    var d = cur - prev;
    if (d === 0) return '<span style="font-size:11px;color:#94a3b8;font-weight:600;">·&nbsp;no change</span>';
    var good = invert ? d < 0 : d > 0;
    var col = good ? '#15803d' : '#b91c1c';
    return '<span style="font-size:11px;color:'+col+';font-weight:700;">' + (d>0?'▲':'▼') + '&nbsp;' + Math.abs(d) + '</span>';
  }
  var included = sites.filter(function(s){ return s.included && s.configured && s.metrics; });
%>

<div class="page-header" style="margin-bottom:14px;">
  <h1 style="margin:0;font-size:26px;letter-spacing:-.5px;">OneBoard</h1>
  <p class="muted" style="margin:4px 0 0;">Dashboard for the whole company — <strong><%= esc(insName || company) %></strong></p>
</div>

<% if (state === 'down') { %>
  <div class="card"><p class="muted" style="margin:0;">Call analytics is temporarily unavailable — please try again shortly.</p></div>
<% } else if (state === 'unlinked') { %>
  <div class="card"><p class="muted" style="margin:0;">Your company isn't linked to call analytics yet. Please contact Lumen IT.</p></div>
<% } else { %>

<!-- Controls: week / range / compare / sites — one row, remembered per user -->
<div class="card" style="margin-bottom:16px;">
  <form method="get" action="/my/oneboard" id="obForm" style="display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap;margin:0;">
    <div>
      <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;margin-bottom:4px;">Week</label>
      <select class="input" id="obWeek" onchange="obSyncWeek()" style="min-width:180px;">
        <option value="">Custom range…</option>
        <% weeks.forEach(function(w){ %><option value="<%= w.mon %>" <%= w.mon===weekSel ? 'selected' : '' %>><%= w.label %></option><% }); %>
      </select>
    </div>
    <div>
      <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;margin-bottom:4px;">Month</label>
      <select class="input" id="obMonth" onchange="obSyncMonth()" style="min-width:160px;">
        <option value="">Custom range…</option>
        <% months.forEach(function(m){ %><option value="<%= m.first %>" data-last="<%= m.last %>" <%= m.first===monthSel ? 'selected' : '' %>><%= m.label %></option><% }); %>
      </select>
    </div>
    <div><label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;margin-bottom:4px;">From</label><input class="input" type="date" name="from" id="obFrom" value="<%= from %>"></div>
    <div><label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;margin-bottom:4px;">To</label><input class="input" type="date" name="to" id="obTo" value="<%= to %>"></div>
    <label style="display:flex;align-items:center;gap:7px;font-size:14px;padding-bottom:9px;cursor:pointer;">
      <input type="checkbox" name="cmp" value="1" <%= compare ? 'checked' : '' %> style="width:auto;"> Compare with previous period
    </label>
    <div style="flex-basis:100%;height:0;"></div>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#64748b;">Sites</span>
      <% sites.forEach(function(s){ %>
        <label style="display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border:1px solid <%= s.included ? '#0ea5b7' : '#e2e8f0' %>;border-radius:999px;font-size:13px;cursor:pointer;background:<%= s.included ? '#ecfeff' : '#fff' %>;">
          <input type="checkbox" class="ob-site" name="sites" value="<%= s.id %>" <%= s.included ? 'checked' : '' %> style="width:auto;min-width:auto;" onchange="this.parentElement.style.borderColor=this.checked?'#0ea5b7':'#e2e8f0';this.parentElement.style.background=this.checked?'#ecfeff':'#fff';">
          <%= esc(s.label) %><% if (!s.configured) { %> <span title="This site's call logic isn't set up yet" style="color:#b45309;font-size:11px;">⚠</span><% } %>
        </label>
      <% }); %>
    </div>
    <div style="display:flex;gap:8px;margin-left:auto;">
      <button class="btn btn-primary" type="submit">Update</button>
      <button class="btn" type="button" id="obSave" onclick="obSaveLayout()">Save as my layout</button>
    </div>
  </form>
</div>

<% if (!included.length) { %>
  <div class="card"><p class="muted" style="margin:0;">No sites selected<%= sites.some(function(s){return !s.configured;}) ? ' — sites marked ⚠ need their call logic set up by Lumen IT before they can appear' : '' %>. Tick a site above and press Update.</p></div>
<% } else { %>

<!-- Branch scorecards -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin-bottom:16px;">
  <% included.forEach(function(s){ var m = s.metrics, p = s.prev; %>
  <div class="card" style="margin:0;">
    <div style="font-size:13px;font-weight:700;color:#0f172a;margin-bottom:10px;"><%= esc(s.label) %></div>
    <div style="display:flex;gap:18px;flex-wrap:wrap;">
      <div><div style="font-size:26px;font-weight:700;line-height:1;color:#0f172a;"><%= m.total %></div><div style="font-size:11px;color:#64748b;margin-top:4px;">Calls <%- delta(m.total, p ? p.total : null, false) %></div></div>
      <div><div style="font-size:26px;font-weight:700;line-height:1;color:#15803d;"><%= m.answered %></div><div style="font-size:11px;color:#64748b;margin-top:4px;">Answered</div></div>
      <div><div style="font-size:26px;font-weight:700;line-height:1;color:#b91c1c;"><%= m.missed %></div><div style="font-size:11px;color:#64748b;margin-top:4px;">Missed <%- delta(m.missed, p ? p.missed : null, true) %></div></div>
      <div><div style="font-size:26px;font-weight:700;line-height:1;color:#0f172a;"><%= m.rate %>%</div><div style="font-size:11px;color:#64748b;margin-top:4px;">Answer rate <%- p ? delta(m.rate, p.rate, false) : '' %></div></div>
    </div>
    <% if (p) { %><div style="font-size:11px;color:#94a3b8;margin-top:8px;">Previous period: <%= p.total %> calls · <%= p.rate %>% answered</div><% } %>
  </div>
  <% }); %>
</div>

<!-- Daily totals: answered v missed per branch -->
<div class="card" style="padding:0;margin-bottom:16px;">
  <div class="card-header" style="padding:14px 18px;"><h2 style="margin:0;">Daily calls — answered v missed</h2></div>
  <div class="table-wrap"><table class="table" style="margin:0;">
    <thead><tr><th style="min-width:110px;">Day</th>
      <% included.forEach(function(s){ %><th colspan="2" style="text-align:center;border-left:1px solid #e2e8f0;"><%= esc(s.label) %></th><% }); %>
    </tr><tr><th></th>
      <% included.forEach(function(){ %><th class="muted" style="text-align:right;font-size:11px;border-left:1px solid #e2e8f0;">Calls</th><th class="muted" style="font-size:11px;min-width:120px;">Ans / Miss</th><% }); %>
    </tr></thead>
    <tbody>
      <% (included[0] ? included[0].daily : []).forEach(function(_, di){ %>
      <tr>
        <td class="muted" style="white-space:nowrap;font-size:13px;"><%= included[0].daily[di].label %></td>
        <% included.forEach(function(s){ var d = s.daily[di] || {total:0,answered:0,missed:0}; var aw = d.total ? Math.round(d.answered/d.total*100) : 0; %>
          <td class="num" style="text-align:right;font-weight:600;border-left:1px solid #f1f5f9;"><%= d.total || '—' %></td>
          <td>
            <% if (d.total) { %>
            <div title="<%= d.answered %> answered · <%= d.missed %> missed" style="display:flex;height:10px;border-radius:5px;overflow:hidden;background:#fee2e2;min-width:110px;">
              <div style="width:<%= aw %>%;background:#22c55e;border-right:<%= (d.answered && d.missed) ? '2px solid #fff' : '0' %>;"></div>
            </div>
            <div style="font-size:11px;color:#64748b;margin-top:2px;"><%= d.answered %> · <span style="color:#b91c1c;"><%= d.missed %></span></div>
            <% } else { %><span class="muted" style="font-size:12px;">—</span><% } %>
          </td>
        <% }); %>
      </tr>
      <% }); %>
    </tbody>
  </table></div>
</div>

<!-- Compiled heatmap: missed calls per hour per branch -->
<div class="card" style="padding:0;">
  <div class="card-header" style="padding:14px 18px;"><h2 style="margin:0;">Missed calls by hour</h2>
    <span class="muted" style="font-size:12px;">Each cell = missed calls in that hour across the selected dates (business hours, local time)</span></div>
  <div class="table-wrap"><table class="table" style="margin:0;">
    <thead><tr><th style="min-width:110px;"></th><% hours.forEach(function(h){ %><th class="muted" style="text-align:center;font-size:11px;"><%= ('0'+h).slice(-2) %>:00</th><% }); %></tr></thead>
    <tbody>
      <% included.forEach(function(s){ %>
      <tr>
        <td style="font-weight:600;font-size:13px;white-space:nowrap;"><%= esc(s.label) %></td>
        <% hours.forEach(function(h){ var n = s.missedByHour[h] || 0; %>
          <td title="<%= esc(s.label) %> · <%= ('0'+h).slice(-2) %>:00 — <%= n %> missed" style="text-align:center;background:<%= heatBg(n) %>;color:<%= heatInk(n) %>;font-size:12px;font-weight:600;min-width:34px;"><%= n || '' %></td>
        <% }); %>
      </tr>
      <% }); %>
    </tbody>
  </table></div>
  <div style="display:flex;align-items:center;gap:6px;padding:10px 18px;font-size:11px;color:#64748b;">
    Fewer <% ['#f8fafc','#d7eef3','#a5dbe6','#5cb8ca','#1f8fa6','#0e6377'].forEach(function(c){ %><span style="width:18px;height:10px;background:<%= c %>;border:1px solid #e2e8f0;border-radius:2px;display:inline-block;"></span><% }); %> More missed
  </div>
</div>

<!-- Compiled heatmap: ALL incoming calls per hour per branch -->
<div class="card" style="padding:0;margin-top:16px;">
  <div class="card-header" style="padding:14px 18px;"><h2 style="margin:0;">All incoming calls by hour</h2>
    <span class="muted" style="font-size:12px;">Each cell = every incoming call in that hour across the selected dates (business hours, local time)</span></div>
  <div class="table-wrap"><table class="table" style="margin:0;">
    <thead><tr><th style="min-width:110px;"></th><% hours.forEach(function(h){ %><th class="muted" style="text-align:center;font-size:11px;"><%= ('0'+h).slice(-2) %>:00</th><% }); %></tr></thead>
    <tbody>
      <% included.forEach(function(s){ %>
      <tr>
        <td style="font-weight:600;font-size:13px;white-space:nowrap;"><%= esc(s.label) %></td>
        <% hours.forEach(function(h){ var n = s.totalByHour[h] || 0; %>
          <td title="<%= esc(s.label) %> · <%= ('0'+h).slice(-2) %>:00 — <%= n %> calls" style="text-align:center;background:<%= heatAllBg(n) %>;color:<%= heatAllInk(n) %>;font-size:12px;font-weight:600;min-width:34px;"><%= n || '' %></td>
        <% }); %>
      </tr>
      <% }); %>
    </tbody>
  </table></div>
  <div style="display:flex;align-items:center;gap:6px;padding:10px 18px;font-size:11px;color:#64748b;">
    Fewer <% ['#f8fafc','#e0e7ff','#c7d2fe','#818cf8','#4f46e5','#312e81'].forEach(function(c){ %><span style="width:18px;height:10px;background:<%= c %>;border:1px solid #e2e8f0;border-radius:2px;display:inline-block;"></span><% }); %> More calls
  </div>
</div>

<% } %>
<% } %>

<script>
function obSyncWeek(){
  var w = document.getElementById('obWeek');
  if (!w || !w.value) return;
  var m = document.getElementById('obMonth'); if (m) m.value = '';
  var f = document.getElementById('obFrom'), t = document.getElementById('obTo');
  f.value = w.value;                                  // Monday
  var d = new Date(w.value + 'T00:00:00Z'); d.setUTCDate(d.getUTCDate() + 6);
  t.value = d.toISOString().slice(0, 10);             // Sunday — BOTH dates, always
}
function obSyncMonth(){
  var m = document.getElementById('obMonth');
  if (!m || !m.value) return;
  var w = document.getElementById('obWeek'); if (w) w.value = '';
  var opt = m.options[m.selectedIndex];
  document.getElementById('obFrom').value = m.value;                       // 1st of month
  document.getElementById('obTo').value = opt.getAttribute('data-last');   // last day — BOTH dates, always
}
function obSaveLayout(){
  var ids = Array.prototype.slice.call(document.querySelectorAll('.ob-site:checked')).map(function(c){ return parseInt(c.value, 10); });
  var btn = document.getElementById('obSave'); btn.disabled = true; btn.textContent = 'Saving…';
  var m = document.querySelector('meta[name="csrf-token"]');
  fetch('/my/oneboard/prefs', { method: 'POST', headers: { 'Content-Type': 'application/json', 'x-csrf-token': m ? m.getAttribute('content') : '' }, body: JSON.stringify({ sites: ids }) })
    .then(function(r){ return r.json(); })
    .then(function(j){ btn.disabled = false; btn.textContent = j.ok ? '✓ Saved' : 'Save as my layout'; if (!j.ok) alert(j.error || 'Could not save.'); setTimeout(function(){ btn.textContent = 'Save as my layout'; }, 2000); })
    .catch(function(){ btn.disabled = false; btn.textContent = 'Save as my layout'; alert('Could not save.'); });
}
</script>

<%- include('footer') %>
