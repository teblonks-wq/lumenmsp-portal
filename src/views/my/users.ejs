<%- include('header', { title: 'People', company: (user && user.displayName) || '', user, active }) %>

<div class="page-header"><h1>People at your company</h1><p class="muted">Contacts we have on file for your organisation. To add or remove someone, please raise a ticket.</p></div>

<div class="card">
  <% if (!people || people.length === 0) { %>
    <div class="empty">No contacts on file yet.</div>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead><tr><th>Name</th><th>Job title</th><th>Email</th><th>Phone</th></tr></thead>
        <tbody>
          <% people.forEach(function(p){ %>
            <tr>
              <td><%= p.full_name || '—' %></td>
              <td class="muted"><%= p.job_title || '—' %></td>
              <td><%= p.email || '—' %></td>
              <td class="muted"><%= p.phone || '—' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('footer', { active }) %>
