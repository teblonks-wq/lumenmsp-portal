<%- include('header', { title: 'Ticket ' + (ticket.ticket_number || ''), company: (user && user.displayName) || '', user, active }) %>
<%
  function sbadge(s){ return s==='resolved'?'badge-sent':(s==='closed'?'badge-inactive':(s && s.indexOf('awaiting')===0?'badge-failed':'badge-primary')); }
  function cap(s){ return s ? s.replace(/_/g,' ').replace(/\b\w/g,function(c){return c.toUpperCase();}) : ''; }
  function fmtDT(x){ return x ? new Date(x).toLocaleString('en-GB', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—'; }
  function initials(n){ n=(n||'').trim(); if(!n) return '?'; var p=n.split(/\s+/); return (p[0].charAt(0) + (p[1]?p[1].charAt(0):'')).toUpperCase(); }
%>

<p style="margin:0 0 12px;"><a class="row-link" href="/my/tickets">&larr; Back to tickets</a></p>

<div class="ticket-wrap">
  <div class="ticket-main">
    <div class="card">
      <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;">
        <h1 style="margin:0;font-size:22px;"><%= ticket.subject || '(no subject)' %></h1>
        <span class="badge <%= sbadge(ticket.status) %>"><%= cap(ticket.status || 'open') %></span>
      </div>
      <p class="muted" style="margin:6px 0 0;">Ref <%= ticket.ticket_number || ('#' + ticket.id) %></p>
    </div>

    <div class="card">
      <h2 style="margin:0 0 10px;font-size:16px;">Add a reply</h2>
      <form method="POST" action="/my/tickets/<%= ticket.id %>/reply">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <textarea id="myReplyBox" name="body" rows="4" maxlength="10000" required placeholder="Type your reply to the support team…" style="width:100%;"></textarea>
        <div style="margin-top:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          <button type="submit" class="btn btn-primary">Send reply</button>
        </div>
      </form>
    </div>

    <div class="card">
      <h2 style="margin:0 0 14px;font-size:16px;">Conversation</h2>

      <% (timeline || []).forEach(function(t){ %>
        <div class="msg <%= t.mine ? 'me' : 'them' %>">
          <div class="avatar" style="background:<%= t.mine ? '#0ea5b7' : '#6366f1' %>;"><%= initials(t.who) %></div>
          <div class="bubble">
            <div class="meta"><span class="who"><%= t.who %></span><% if (t.at) { %> &middot; <%= fmtDT(t.at) %><% } %></div>
            <div class="body"><%= t.body %></div>
          </div>
        </div>
      <% }); %>

      <div class="msg me">
        <div class="avatar" style="background:#0ea5b7;"><%= initials('You') %></div>
        <div class="bubble">
          <div class="meta"><span class="who">You</span> &middot; opened the ticket<% if (ticket.created_at) { %> &middot; <%= fmtDT(ticket.created_at) %><% } %></div>
          <div class="body"><%= ticket.description || '' %></div>
        </div>
      </div>
    </div>
  </div>

  <aside class="ticket-side">
    <div class="card">
      <h2 style="margin:0 0 12px;font-size:15px;">Details</h2>
      <dl class="meta-list">
        <dt>Status</dt><dd><span class="badge <%= sbadge(ticket.status) %>"><%= cap(ticket.status || 'open') %></span></dd>
        <dt>Assigned to</dt><dd><%= assignedTo || 'Awaiting assignment' %></dd>
        <dt>Reference</dt><dd><%= ticket.ticket_number || ('#' + ticket.id) %></dd>
        <% if (ticket.category) { %><dt>Category</dt><dd><%= cap(ticket.category) %></dd><% } %>
        <dt>Created</dt><dd><%= fmtDT(ticket.created_at) %></dd>
        <dt>Last updated</dt><dd><%= fmtDT(ticket.updated_at) %></dd>
      </dl>
    </div>
  </aside>
</div>

<style>
  .ticket-wrap { display:grid; grid-template-columns:minmax(0,1fr) 280px; gap:16px; align-items:start; }
  @media (max-width:820px){ .ticket-wrap { grid-template-columns:1fr; } }
  .msg { display:flex; gap:10px; margin:0 0 14px; align-items:flex-start; }
  .msg.me { flex-direction:row-reverse; }
  .avatar { width:34px; height:34px; border-radius:50%; color:#fff; font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .bubble { max-width:80%; border:1px solid var(--line); border-radius:12px; padding:10px 13px; }
  .msg.me .bubble { background:#ecfeff; border-color:#a5f3fc; }
  .msg.them .bubble { background:#f8fafc; }
  .bubble .meta { font-size:12px; color:#64748b; margin-bottom:4px; }
  .bubble .who { font-weight:600; color:#334155; }
  .bubble .body { white-space:pre-wrap; line-height:1.55; }
  .meta-list { display:grid; grid-template-columns:auto 1fr; gap:9px 12px; margin:0; font-size:13px; }
  .meta-list dt { color:#64748b; }
  .meta-list dd { margin:0; font-weight:600; text-align:right; }
</style>


<%- include('footer', { active }) %>
