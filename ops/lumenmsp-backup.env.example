# /etc/lumenmsp-backup.env  — config + secrets for backup.sh (Azure Blob edition)
# Copy to /etc/lumenmsp-backup.env on the server, fill in, then:  sudo chmod 600 /etc/lumenmsp-backup.env

# --- Encryption (REQUIRED — store this passphrase in your vault, separate from the backups) ---
# Without it you cannot decrypt the backups. Make it long and random.
BACKUP_PASSPHRASE="change-me-to-a-long-random-string"

# --- Azure Blob target (where backups are shipped off-box) ---
AZ_ACCOUNT="webobjects"
AZ_KEY="PASTE-YOUR-ROTATED-ACCESS-KEY-HERE"   # NEVER commit/paste this anywhere but here
AZ_CONTAINER="lumenmsp"
AZ_PREFIX="portal-backups/"                    # subfolder inside the container

# --- Which databases to dump (space-separated) ---
# Check yours with:  sudo -u postgres psql -l
DBS="lumenmsp_portal lumenmsp_insights"

# --- Optional ---
RETENTION_DAYS="30"
APP_DIR="/srv/apps/lumenmsp-portal"
PGUSER="postgres"
STAGING="/var/backups/lumenmsp"
# Teams failure alert (reuse the Portal's Power Automate webhook, or any incoming webhook):
TEAMS_WEBHOOK=""
