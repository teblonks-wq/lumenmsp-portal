<%- include('../partials/header', { title: customer.name + ' — Calls', user }) %>
<% function money(v){ return '£' + (Number(v)||0).toLocaleString('en-GB',{minimumFractionDigits:2,maximumFractionDigits:2}); }
   function money4(v){ return '£' + (Number(v)||0).toFixed(4); }
   function dur(s){ s=Number(s)||0; var m=Math.floor(s/60), ss=s%60; return m+':'+(ss<10?'0':'')+ss; }
   function dt(x){ return x ? new Date(x).toLocaleString('en-GB',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) : ''; }
   var totCost = (calls||[]).reduce(function(a,c){return a+Number(c.cost||0);},0);
   var totSell = (calls||[]).reduce(function(a,c){return a+Number(c.sell||0);},0);
   var totSecs = (calls||[]).reduce(function(a,c){return a+Number(c.duration_sec||0);},0); %>

<div class="page-header"><p class="muted" style="margin:0 0 4px;"><a class="row-link" href="/customers/<%= customer.id %>#comms">← <%= customer.name %></a></p>
  <h1>Calls — <%= customer.name %><% if (period) { %> <span class="muted" style="font-weight:400;">· <%= period %></span><% } %></h1></div>

<div style="margin-bottom:14px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
  <form method="get" action="/customers/<%= customer.id %>/calls" style="display:flex;gap:8px;align-items:center;margin:0;">
    <label class="muted" style="font-size:12px;">Period</label>
    <select class="input" name="period" onchange="this.form.submit()" style="width:auto;font-size:13px;padding:5px 8px;">
      <option value="">All periods</option>
      <% (periods||[]).forEach(function(p){ %><option value="<%= p %>" <%= period===p?'selected':'' %>><%= p %></option><% }); %>
    </select>
  </form>
  <a class="btn" href="/customers/<%= customer.id %>/calls.csv<%= period ? '?period=' + encodeURIComponent(period) : '' %>" title="Every itemised call<%= period ? ' in ' + period : '' %> as a spreadsheet-ready CSV">⬇ Download CSV</a>
</div>

<div class="card" style="display:flex;gap:26px;flex-wrap:wrap;margin-bottom:14px;align-items:center;">
  <div><div class="muted" style="font-size:12px;">Calls</div><div style="font-size:20px;font-weight:800;"><%= (calls||[]).length.toLocaleString() %></div></div>
  <div><div class="muted" style="font-size:12px;">Minutes</div><div style="font-size:20px;font-weight:800;"><%= Math.round(totSecs/60).toLocaleString() %></div></div>
  <div><div class="muted" style="font-size:12px;">Cost</div><div style="font-size:20px;font-weight:800;color:#64748b;"><%= money(totCost) %></div></div>
  <div><div class="muted" style="font-size:12px;">Sell</div><div style="font-size:20px;font-weight:800;"><%= money(totSell) %></div></div>
  <div><div class="muted" style="font-size:12px;">Margin</div><div style="font-size:20px;font-weight:800;color:#166534;"><%= money(totSell-totCost) %></div></div>
</div>

<% var st = (typeof stats !== 'undefined' && stats) ? stats : null; %>
<% if (st && (calls||[]).length) { %>
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px;margin-bottom:14px;align-items:stretch;">
  <div class="card">
    <h2 style="font-size:14px;margin:0 0 4px;">Calls per <%= st.bucketLabel %></h2>
    <p class="muted" style="font-size:11px;margin:0 0 8px;"><%= st.bucketLabel==='month' ? 'Every billing period on record' : 'Daily volume in ' + period %> — hover a bar for the detail</p>
    <div id="chartVol" style="width:100%;"></div>
  </div>
  <div class="card">
    <h2 style="font-size:14px;margin:0 0 4px;">Sell by call type</h2>
    <p class="muted" style="font-size:11px;margin:0 0 8px;">Where the call revenue comes from<%= period ? ' in ' + period : '' %></p>
    <div id="chartType" style="width:100%;"></div>
  </div>
  <div class="card" style="padding-bottom:10px;">
    <h2 style="font-size:14px;margin:0 0 4px;">Top 5 CLIs</h2>
    <p class="muted" style="font-size:11px;margin:0 0 8px;">Busiest lines by number of calls<%= period ? ' in ' + period : '' %></p>
    <table class="table" style="font-size:12px;">
      <thead><tr><th></th><th>CLI</th><th style="text-align:right;">Calls</th><th style="text-align:right;">Minutes</th><th style="text-align:right;">Sell</th></tr></thead>
      <tbody>
        <% st.topClis.forEach(function(t, i){ %>
          <tr>
            <td class="muted" style="width:24px;"><%= i+1 %></td>
            <td style="font-weight:600;"><%= t.cli %></td>
            <td style="text-align:right;"><%= t.n.toLocaleString() %></td>
            <td style="text-align:right;"><%= Math.round(t.secs/60).toLocaleString() %></td>
            <td style="text-align:right;"><%= money(t.sell) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
(function(){
  var STATS = <%- JSON.stringify(st) %>;
  var INK = '#334155', MUTED = '#94a3b8', GRID = '#e2e8f0', BAR = '#0e6377';
  function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]; }); }
  function gbp(v){ return '£' + (Number(v)||0).toLocaleString('en-GB',{minimumFractionDigits:2,maximumFractionDigits:2}); }
  function monthLabel(k){ // '2026-07' -> 'Jul 26'; '2026-07-03' -> '3 Jul'
    var p = String(k).split('-');
    var M = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    if (p.length === 2) return M[(+p[1])-1] + ' ' + p[0].slice(2);
    if (p.length === 3) return (+p[2]) + ' ' + M[(+p[1])-1];
    return k;
  }

  // ── Calls per day/month — vertical bars, one series, native tooltips ──────────
  (function(){
    var data = STATS.byBucket || [];
    var host = document.getElementById('chartVol');
    if (!host || !data.length) { if (host) host.innerHTML = '<p class="muted" style="font-size:12px;">No dated calls to chart.</p>'; return; }
    var W = 560, H = 170, padL = 34, padB = 20, padT = 8;
    var plotW = W - padL - 6, plotH = H - padT - padB;
    var max = Math.max.apply(null, data.map(function(d){ return d.n; })) || 1;
    var step = plotW / data.length;
    var bw = Math.max(2, Math.min(26, step - 2));
    var s = '<svg viewBox="0 0 ' + W + ' ' + H + '" style="width:100%;height:auto;display:block;" role="img" aria-label="Calls per ' + esc(STATS.bucketLabel) + '">';
    // recessive grid: 3 lines + y labels
    for (var g = 1; g <= 3; g++) {
      var gy = padT + plotH - (plotH * g / 3);
      s += '<line x1="' + padL + '" y1="' + gy + '" x2="' + W + '" y2="' + gy + '" stroke="' + GRID + '" stroke-width="1"/>';
      s += '<text x="' + (padL - 5) + '" y="' + (gy + 3.5) + '" text-anchor="end" font-size="9" fill="' + MUTED + '">' + Math.round(max * g / 3).toLocaleString() + '</text>';
    }
    s += '<line x1="' + padL + '" y1="' + (padT + plotH) + '" x2="' + W + '" y2="' + (padT + plotH) + '" stroke="' + GRID + '" stroke-width="1"/>';
    var labelEvery = Math.max(1, Math.ceil(data.length / 8));
    data.forEach(function(d, i){
      var h = Math.max(1.5, plotH * d.n / max);
      var x = padL + i * step + (step - bw) / 2;
      var y = padT + plotH - h;
      s += '<g><rect x="' + x + '" y="' + y + '" width="' + bw + '" height="' + h + '" rx="2" fill="' + BAR + '">'
         + '<title>' + esc(monthLabel(d.k)) + ' — ' + d.n.toLocaleString() + ' call(s), ' + Math.round(d.secs/60).toLocaleString() + ' min, ' + esc(gbp(d.sell)) + '</title></rect></g>';
      if (i % labelEvery === 0 || i === data.length - 1) {
        s += '<text x="' + (x + bw/2) + '" y="' + (H - 6) + '" text-anchor="middle" font-size="9" fill="' + MUTED + '">' + esc(monthLabel(d.k)) + '</text>';
      }
    });
    s += '</svg>';
    host.innerHTML = s;
  })();

  // ── Sell by call type — horizontal bars, one hue (magnitude), direct labels ───
  (function(){
    var data = (STATS.byType || []).filter(function(d){ return d.n > 0; }).slice(0, 8);
    var host = document.getElementById('chartType');
    if (!host || !data.length) { if (host) host.innerHTML = '<p class="muted" style="font-size:12px;">Nothing to chart.</p>'; return; }
    var W = 560, rowH = 26, H = data.length * rowH + 4;
    var labW = 150, valW = 74;
    var plotW = W - labW - valW;
    var max = Math.max.apply(null, data.map(function(d){ return d.sell; })) || 0;
    var s = '<svg viewBox="0 0 ' + W + ' ' + H + '" style="width:100%;height:auto;display:block;" role="img" aria-label="Sell by call type">';
    data.forEach(function(d, i){
      var y = i * rowH + 4;
      var w = max > 0 ? Math.max(1.5, plotW * d.sell / max) : 1.5;
      s += '<text x="' + (labW - 8) + '" y="' + (y + 13) + '" text-anchor="end" font-size="11" fill="' + INK + '">' + esc(d.label) + '</text>';
      s += '<g><rect x="' + labW + '" y="' + y + '" width="' + w + '" height="16" rx="2" fill="' + BAR + '">'
         + '<title>' + esc(d.label) + ' — ' + d.n.toLocaleString() + ' call(s), ' + esc(gbp(d.sell)) + '</title></rect></g>';
      s += '<text x="' + (labW + w + 6) + '" y="' + (y + 13) + '" font-size="11" fill="' + INK + '">' + esc(gbp(d.sell)) + '</text>';
    });
    s += '</svg>';
    host.innerHTML = s;
  })();
})();
</script>
<% } %>

<div class="card" style="padding:0;">
  <div class="card-header" style="padding:16px 20px 0;"><h2>Calls — highest value first <span class="muted" style="font-weight:500;font-size:12px;">(<%= (calls||[]).length.toLocaleString() %>)</span></h2></div>
  <% if (!(calls||[]).length) { %>
    <p class="muted" style="padding:14px 20px;">No call records for this customer<% if (period) { %> in <%= period %><% } %>.</p>
  <% } else { %>
    <div class="table-wrap"><table class="table">
      <thead><tr>
        <th>When</th><th>CLI</th><th>Dialled</th><th>Description</th><th>Type</th>
        <th style="text-align:right;">Duration</th><th style="text-align:right;">Cost</th><th style="text-align:right;">Sell</th>
      </tr></thead>
      <tbody>
        <% calls.forEach(function(c){ var cost=Number(c.cost||0); %>
          <tr>
            <td style="white-space:nowrap;font-size:12px;"><%= dt(c.call_at) %></td>
            <td style="font-size:12px;"><%= c.cli || '' %></td>
            <td style="font-size:12px;"><%= c.dialled || '' %></td>
            <td class="muted" style="font-size:12px;"><%= c.description || '' %></td>
            <td style="font-size:11px;"><%= c.call_type_label || '' %><% if (cost>0) { %> <span class="muted">(+<%= c.markup_pct %>%)</span><% } %></td>
            <td style="text-align:right;font-size:12px;"><%= dur(c.duration_sec) %></td>
            <td style="text-align:right;"><%= money4(cost) %></td>
            <td style="text-align:right;"><%= money4(c.sell||0) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table></div>
  <% } %>
</div>

<%- include('../partials/footer') %>
